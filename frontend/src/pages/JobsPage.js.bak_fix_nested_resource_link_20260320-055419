import React, { useState, useEffect } from 'react';
import { Link } from 'react-router-dom';
import { useAuth } from '@/contexts/AuthContext';
import api from '@/lib/api';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogFooter,
  DialogHeader,
  DialogTitle,
  DialogTrigger,
} from '@/components/ui/dialog';
import { Label } from '@/components/ui/label';
import {
  Plus,
  Search,
  Briefcase,
  MapPin,
  Building2,
  Calendar,
  ArrowRight,
  Loader2,
} from 'lucide-react';
import { toast } from 'sonner';

export default function JobsPage() {
  const { canManage } = useAuth();
  const [jobs, setJobs] = useState([]);
  const [loading, setLoading] = useState(true);
  const [search, setSearch] = useState('');
  const [dialogOpen, setDialogOpen] = useState(false);
  const [saving, setSaving] = useState(false);
  const [newJob, setNewJob] = useState({
    job_number: '',
    job_name: '',
    main_contractor: '',
    site_address: '',
    planned_start: '',
    planned_finish: '',
    max_crew: '',
    standard_crew: '',
    allow_saturday: false,
    allow_overtime: false,
  });

  useEffect(() => {
    fetchJobs();
  }, []);

  const fetchJobs = async () => {
    try {
      const response = await api.get('/jobs');
      setJobs(response.data);
    } catch (error) {
      toast.error('Failed to load jobs');
    } finally {
      setLoading(false);
    }
  };

  const handleCreateJob = async (e) => {
    e.preventDefault();
    setSaving(true);
    try {
      const response = await api.post('/jobs', newJob);
      setJobs([response.data, ...jobs]);
      setDialogOpen(false);
      setNewJob({
        job_number: '',
        job_name: '',
        main_contractor: '',
        site_address: '',
        planned_start: '',
        planned_finish: '',
    max_crew: '',
    standard_crew: '',
    allow_saturday: false,
    allow_overtime: false,
      });
      toast.success('Job created with standard task codes assigned!');
    } catch (error) {
      toast.error(error.response?.data?.detail || 'Failed to create job');
    } finally {
      setSaving(false);
    }
  };

  const filteredJobs = jobs.filter(job => 
    job.job_number.toLowerCase().includes(search.toLowerCase()) ||
    job.job_name.toLowerCase().includes(search.toLowerCase()) ||
    job.main_contractor?.toLowerCase().includes(search.toLowerCase())
  );

  const getStatusColor = (status) => {
    switch (status) {
      case 'active': return 'default';
      case 'completed': return 'secondary';
      case 'on_hold': return 'outline';
      default: return 'secondary';
    }
  };

  return (
    <div className="space-y-6" data-testid="jobs-page">
      {/* Header */}
      <div className="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h1 className="text-3xl font-bold font-['Manrope']">Jobs</h1>
          <p className="text-muted-foreground mt-1">Manage your fitout projects</p>
        </div>
        {canManage() && (
          <div className="flex gap-2">
            <Link to="/jobs/new">
              <Button variant="outline" data-testid="job-setup-wizard-btn">
                <Plus className="mr-2 h-4 w-4" />
                Setup Wizard
              </Button>
            </Link>
            <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>
              <DialogTrigger asChild>
                <Button data-testid="quick-create-job-btn">
                  <Plus className="mr-2 h-4 w-4" />
                  Quick Create
                </Button>
              </DialogTrigger>
              <DialogContent className="sm:max-w-[500px]">
                <form onSubmit={handleCreateJob}>
                  <DialogHeader>
                    <DialogTitle>Create New Job</DialogTitle>
                    <DialogDescription>
                      Enter the basic job details. You can add more later.
                    </DialogDescription>
                  </DialogHeader>
                  <div className="grid gap-4 py-4">
                    <div className="grid grid-cols-4 items-center gap-4">
                      <Label htmlFor="job_number" className="text-right">Job #</Label>
                      <Input
                        id="job_number"
                        value={newJob.job_number}
                        onChange={(e) => setNewJob({ ...newJob, job_number: e.target.value })}
                        className="col-span-3"
                        placeholder="e.g. 2024-001"
                        required
                        data-testid="job-number-input"
                      />
                    </div>
                    <div className="grid grid-cols-4 items-center gap-4">
                      <Label htmlFor="job_name" className="text-right">Name</Label>
                      <Input
                        id="job_name"
                        value={newJob.job_name}
                        onChange={(e) => setNewJob({ ...newJob, job_name: e.target.value })}
                        className="col-span-3"
                        placeholder="e.g. ABC Office Fitout"
                        required
                        data-testid="job-name-input"
                      />
                    </div>
                    <div className="grid grid-cols-4 items-center gap-4">
                      <Label htmlFor="main_contractor" className="text-right">Main Contractor</Label>
                      <Input
                        id="main_contractor"
                        value={newJob.main_contractor}
                        onChange={(e) => setNewJob({ ...newJob, main_contractor: e.target.value })}
                        className="col-span-3"
                        placeholder="e.g. Fletcher Construction"
                        data-testid="main-contractor-input"
                      />
                    </div>
                    <div className="grid grid-cols-4 items-center gap-4">
                      <Label htmlFor="site_address" className="text-right">Site Address</Label>
                      <Input
                        id="site_address"
                        value={newJob.site_address}
                        onChange={(e) => setNewJob({ ...newJob, site_address: e.target.value })}
                        className="col-span-3"
                        placeholder="e.g. 123 Queen St, Auckland"
                        data-testid="site-address-input"
                      />
                    </div>
                    <div className="grid grid-cols-4 items-center gap-4">
                      <Label htmlFor="planned_start" className="text-right">Start Date</Label>
                      <Input
                        id="planned_start"
                        type="date"
                        value={newJob.planned_start}
                        onChange={(e) => setNewJob({ ...newJob, planned_start: e.target.value })}
                        className="col-span-3"
                        data-testid="start-date-input"
                      />
                    </div>
                    <div className="grid grid-cols-4 items-center gap-4">
                      <Label htmlFor="planned_finish" className="text-right">End Date</Label>
                      <Input
                        id="planned_finish"
                        type="date"
                        value={newJob.planned_finish}
                        onChange={(e) => setNewJob({ ...newJob, planned_finish: e.target.value })}
                        className="col-span-3"
                        data-testid="end-date-input"
                      />
                    </div>
                    <div className="grid grid-cols-4 items-center gap-4">
                      <Label htmlFor="standard_crew" className="text-right">Std Crew</Label>
                      <Input
                        id="standard_crew"
                        type="number"
                        min="0"
                        step="0.5"
                        value={newJob.standard_crew}
                        onChange={(e) => setNewJob({ ...newJob, standard_crew: e.target.value })}
                        className="col-span-3"
                        placeholder="e.g. 4"
                      />
                    </div>
                    <div className="grid grid-cols-4 items-center gap-4">
                      <Label htmlFor="max_crew" className="text-right">Max Crew</Label>
                      <Input
                        id="max_crew"
                        type="number"
                        min="0"
                        step="0.5"
                        value={newJob.max_crew}
                        onChange={(e) => setNewJob({ ...newJob, max_crew: e.target.value })}
                        className="col-span-3"
                        placeholder="e.g. 6"
                      />
                    </div>
                    <div className="grid grid-cols-4 items-center gap-4">
                      <Label htmlFor="allow_saturday" className="text-right">Saturday</Label>
                      <div className="col-span-3">
                        <input
                          id="allow_saturday"
                          type="checkbox"
                          checked={newJob.allow_saturday}
                          onChange={(e) => setNewJob({ ...newJob, allow_saturday: e.target.checked })}
                          className="h-4 w-4"
                        />
                      </div>
                    </div>
                    <div className="grid grid-cols-4 items-center gap-4">
                      <Label htmlFor="allow_overtime" className="text-right">Overtime</Label>
                      <div className="col-span-3">
                        <input
                          id="allow_overtime"
                          type="checkbox"
                          checked={newJob.allow_overtime}
                          onChange={(e) => setNewJob({ ...newJob, allow_overtime: e.target.checked })}
                          className="h-4 w-4"
                        />
                      </div>
                    </div>
                  </div>
                  <DialogFooter>
                    <Button type="button" variant="outline" onClick={() => setDialogOpen(false)}>
                      Cancel
                    </Button>
                    <Button type="submit" disabled={saving} data-testid="save-job-btn">
                      {saving && <Loader2 className="mr-2 h-4 w-4 animate-spin" />}
                      Create Job
                    </Button>
                  </DialogFooter>
                </form>
              </DialogContent>
            </Dialog>
          </div>
        )}
      </div>

      {/* Search */}
      <div className="relative max-w-md">
        <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
        <Input
          placeholder="Search jobs..."
          value={search}
          onChange={(e) => setSearch(e.target.value)}
          className="pl-10"
          data-testid="search-jobs"
        />
      </div>

      {/* Jobs Grid */}
      {loading ? (
        <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {[...Array(6)].map((_, i) => (
            <Card key={i} className="animate-pulse">
              <CardContent className="p-6">
                <div className="h-32 bg-muted rounded" />
              </CardContent>
            </Card>
          ))}
        </div>
      ) : filteredJobs.length === 0 ? (
        <Card>
          <CardContent className="flex flex-col items-center justify-center py-12">
            <Briefcase className="h-16 w-16 text-muted-foreground/50 mb-4" />
            <h3 className="text-lg font-medium">No jobs found</h3>
            <p className="text-muted-foreground text-center mt-2">
              {search ? 'Try adjusting your search terms' : 'Get started by creating your first job'}
            </p>
            {canManage() && !search && (
              <Link to="/jobs/new" className="mt-4">
                <Button>
                  <Plus className="mr-2 h-4 w-4" />
                  Create Job
                </Button>
              </Link>
            )}
          </CardContent>
        </Card>
      ) : (
        <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {filteredJobs.map((job) => (
            <Link key={job.id} to={`/jobs/${job.id}`} data-testid={`job-card-${job.job_number}`}>
              <Card className="card-hover h-full">
                <CardHeader className="pb-2">
                  <div className="flex items-center justify-between">
                    <span className="font-mono text-sm text-muted-foreground">{job.job_number}</span>
                    <Badge variant={getStatusColor(job.status)}>{job.status}</Badge>
                  </div>
                  <CardTitle className="text-lg mt-2 line-clamp-2">{job.job_name}</CardTitle>
                </CardHeader>
                <CardContent className="space-y-3">
                  {job.main_contractor && (
                    <div className="flex items-center gap-2 text-sm text-muted-foreground">
                      <Building2 className="h-4 w-4 flex-shrink-0" />
                      <span className="truncate">{job.main_contractor}</span>
                    </div>
                  )}
                  {job.site_address && (
                    <div className="flex items-center gap-2 text-sm text-muted-foreground">
                      <MapPin className="h-4 w-4 flex-shrink-0" />
                      <span className="truncate">{job.site_address}</span>
                    </div>
                  )}
                  {(job.planned_start || job.planned_finish) && (
                    <div className="flex items-center gap-2 text-sm text-muted-foreground">
                      <Calendar className="h-4 w-4 flex-shrink-0" />
                      <span>
                        {job.planned_start && new Date(job.planned_start).toLocaleDateString()}
                        {job.planned_start && job.planned_finish && ' - '}
                        {job.planned_finish && new Date(job.planned_finish).toLocaleDateString()}
                      </span>
                    </div>
                  )}
                  <div className="flex items-center justify-between pt-2">
  <Link to={`/resource-analysis/${job.id}`}>
    <Button size="sm" variant="outline">
      Resource Analysis
    </Button>
  </Link>
  <span className="text-sm text-primary flex items-center gap-1">
    View details <ArrowRight className="h-4 w-4" />
  </span>
</div>
                </CardContent>
              </Card>
            </Link>
          ))}
        </div>
      )}
    </div>
  );
}



