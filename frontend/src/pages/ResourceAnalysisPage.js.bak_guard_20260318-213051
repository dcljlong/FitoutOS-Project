import React, { useEffect, useState } from "react";
import { useParams } from "react-router-dom";
import api from "@/lib/api";
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import { Loader2 } from "lucide-react";
import { toast } from "sonner";

const formatHours = (value) => {
  if (value === null || value === undefined || value === "") return "-";
  const num = Number(value);
  if (Number.isNaN(num)) return "-";
  return `${num.toFixed(2)}h`;
};

const formatNumber = (value, digits = 1) => {
  if (value === null || value === undefined || value === "") return "-";
  const num = Number(value);
  if (Number.isNaN(num)) return "-";
  return num.toFixed(digits);
};

const formatPercent = (value) => {
  if (value === null || value === undefined || value === "") return "-";
  const num = Number(value);
  if (Number.isNaN(num)) return "-";
  return `${num.toFixed(1)}%`;
};

const statusClass = (status) => {
  switch (status) {
    case "ON_TRACK":
      return "bg-green-100 text-green-800 border border-green-200";
    case "SATURDAY_REQUIRED":
      return "bg-amber-100 text-amber-800 border border-amber-200";
    case "OVERALLOCATED":
      return "bg-red-100 text-red-800 border border-red-200";
    case "NO_QUOTED_HOURS":
      return "bg-slate-100 text-slate-800 border border-slate-200";
    default:
      return "bg-slate-100 text-slate-700 border border-slate-200";
  }
};

export default function ResourceAnalysisPage() {
  const { jobId } = useParams();
  const [loading, setLoading] = useState(true);
  const [analysis, setAnalysis] = useState(null);

  useEffect(() => {
    const loadAnalysis = async () => {
      if (!jobId) {
        setLoading(false);
        return;
      }

      setLoading(true);
      try {
        const res = await api.get(`/jobs/${jobId}/resource-analysis`);
        setAnalysis(res.data);
      } catch (error) {
        console.error(error);
        toast.error("Failed to load resource analysis");
        setAnalysis(null);
      } finally {
        setLoading(false);
      }
    };

    loadAnalysis();
  }, [jobId]);

  if (loading) {
    return (
      <div className="flex items-center justify-center min-h-[400px]">
        <Loader2 className="h-8 w-8 animate-spin text-primary" />
      </div>
    );
  }

  if (!analysis) {
    return (
      <div className="space-y-6" data-testid="resource-analysis-page">
        <div>
          <h1 className="text-3xl font-bold font-['Manrope']">Resource Analysis</h1>
          <p className="text-muted-foreground mt-1">Labour intelligence by task</p>
        </div>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">No Data</CardTitle>
            <CardDescription>No resource analysis data available for this job.</CardDescription>
          </CardHeader>
        </Card>
      </div>
    );
  }

  const summary = analysis.summary || {};

  return (
    <div className="space-y-6" data-testid="resource-analysis-page">
      <div className="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
        <div>
          <h1 className="text-3xl font-bold font-['Manrope']">Resource Analysis</h1>
          <p className="text-muted-foreground mt-1">
            {analysis.job_number} - {analysis.job_name}
          </p>
        </div>
        <div className={`inline-flex w-fit items-center rounded-md px-3 py-1.5 text-sm font-semibold ${statusClass(summary.overall_status)}`}>
          {summary.overall_status || "-"}
        </div>
      </div>

      <div className="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
        <Card>
          <CardContent className="pt-6">
            <p className="text-sm text-muted-foreground">Total Tasks</p>
            <p className="text-2xl font-bold">{summary.total_tasks ?? "-"}</p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="pt-6">
            <p className="text-sm text-muted-foreground">Total Quoted</p>
            <p className="text-2xl font-bold">{formatHours(summary.total_quoted_hours)}</p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="pt-6">
            <p className="text-sm text-muted-foreground">Total Actual</p>
            <p className="text-2xl font-bold">{formatHours(summary.total_actual_hours)}</p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="pt-6">
            <p className="text-sm text-muted-foreground">Variance</p>
            <p className="text-2xl font-bold">{formatHours(summary.total_hours_variance)}</p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="pt-6">
            <p className="text-sm text-muted-foreground">Hours Used</p>
            <p className="text-2xl font-bold">{formatPercent(summary.percent_hours_used)}</p>
          </CardContent>
        </Card>
      </div>

      <div className="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        <Card>
          <CardHeader>
            <CardTitle className="text-lg">Programme Capacity</CardTitle>
            <CardDescription>Available labour window from programme dates</CardDescription>
          </CardHeader>
          <CardContent className="space-y-2">
            <div className="flex items-center justify-between gap-4">
              <span className="text-sm text-muted-foreground">Standard Hours</span>
              <span className="font-semibold">{formatHours(summary.total_available_hours_standard)}</span>
            </div>
            <div className="flex items-center justify-between gap-4">
              <span className="text-sm text-muted-foreground">With Saturday</span>
              <span className="font-semibold">{formatHours(summary.total_available_hours_with_saturday)}</span>
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">Quoted Baseline</CardTitle>
            <CardDescription>Current approved labour baseline for this job</CardDescription>
          </CardHeader>
          <CardContent className="space-y-2">
            <div className="flex items-center justify-between gap-4">
              <span className="text-sm text-muted-foreground">Approved Scope Hours</span>
              <span className="font-semibold">{formatHours(summary.total_approved_scope_hours)}</span>
            </div>
            <div className="flex items-center justify-between gap-4">
              <span className="text-sm text-muted-foreground">Baseline Used</span>
              <span className="font-semibold">{formatHours(summary.baseline_hours_used)}</span>
            </div>
          </CardContent>
        </Card>
      </div>

      <Card>
        <CardHeader>
          <CardTitle className="text-lg">Task Breakdown</CardTitle>
          <CardDescription>Quoted, actual, crew demand, and programme status by task</CardDescription>
        </CardHeader>
        <CardContent>
          <div className="overflow-x-auto">
            <table className="data-table w-full">
              <thead>
                <tr>
                  <th>Task Name</th>
                  <th className="text-right">Quoted</th>
                  <th className="text-right">Actual</th>
                  <th className="text-right">Variance</th>
                  <th className="text-right">% Used</th>
                  <th className="text-right">Crew</th>
                  <th>Saturday</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                {analysis.tasks.map((task) => (
                  <tr key={task.task_id}>
                    <td>{task.task_name}</td>
                    <td className="text-right">{formatHours(task.quoted_hours)}</td>
                    <td className="text-right">{formatHours(task.actual_hours)}</td>
                    <td className="text-right">{formatHours(task.hours_variance)}</td>
                    <td className="text-right">{formatPercent(task.percent_hours_used)}</td>
                    <td className="text-right">{formatNumber(task.required_crew_standard, 2)}</td>
                    <td>{task.requires_saturday ? "Yes" : "No"}</td>
                    <td>
                      <span className={`inline-flex items-center rounded-md px-2 py-1 text-xs font-semibold ${statusClass(task.programme_feasible)}`}>
                        {task.programme_feasible ?? "-"}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </CardContent>
      </Card>
    </div>
  );
}
