              <Card>
                <CardContent className="pt-6">
                  <ScrollArea className="h-[400px]">
                    {(jobTaskCodes.length ? jobTaskCodes : analysis?.proposed_task_codes)?.length > 0 ? (
                      <div className="space-y-2">
                        {(jobTaskCodes.length ? jobTaskCodes : analysis?.proposed_task_codes).map((code, index) => (
                          <div key={index} className="flex items-start gap-3 p-3 rounded-lg border">
                            <div className="flex-1 min-w-0">
                              <span className="font-mono font-bold">{typeof code === "string" ? code : code.code}</span>
                              {code.reason && (
                                <p className="text-sm text-muted-foreground mt-1">{code.reason}</p>
                              )}
                            </div>
                          </div>
                        ))}
                      </div>
                    ) : (
                      <p className="text-muted-foreground text-center py-8">
                        No task codes suggested
                      </p>
                    )}
                  </ScrollArea>
                </CardContent>
              </Card>
            </TabsContent>
            <TabsContent value="programme">
  <Card>
    <CardContent className="pt-6">
      {/* Parse Warnings Display */}
      {parseResult && (parseResult.warnings?.length > 0 || parseResult.errors?.length > 0) && (
        <div className="mb-4 space-y-2">
          {parseResult.errors?.length > 0 && (
            <div className="p-3 bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-800 rounded-lg">
              <div className="flex items-center gap-2 text-red-700 dark:text-red-300 font-medium mb-2">
                <AlertCircle className="h-4 w-4" />
                Parse Errors ({parseResult.errors.length})
              </div>
              <ul className="text-sm text-red-600 dark:text-red-400 space-y-1 ml-6">
                {parseResult.errors.map((err, idx) => (
                  <li key={idx}>Row {err.row}: {err.message}</li>
                ))}
              </ul>
            </div>
          )}
          {parseResult.warnings?.length > 0 && (
            <div className="p-3 bg-amber-50 dark:bg-amber-950/20 border border-amber-200 dark:border-amber-800 rounded-lg">
              <div className="flex items-center gap-2 text-amber-700 dark:text-amber-300 font-medium mb-2">
                <AlertCircle className="h-4 w-4" />
                Parse Warnings ({parseResult.warnings.length}) - Review items below
              </div>
              <ul className="text-sm text-amber-600 dark:text-amber-400 space-y-1 ml-6 max-h-32 overflow-y-auto">
                {parseResult.warnings.map((warn, idx) => (
                  <li key={idx}>{warn.row > 0 ? `Row ${warn.row}: ` : ''}{warn.message}</li>
                ))}
              </ul>
            </div>
          )}
          {parseResult.metadata && (
            <div className="p-2 bg-muted/50 rounded text-xs text-muted-foreground flex flex-wrap gap-4">
              <span>Source: {parseResult.filename}</span>
              <span>Header at row: {parseResult.metadata.header_row_found}</span>
              <span>Blank rows skipped: {parseResult.metadata.blank_rows_skipped}</span>
              {parseResult.metadata.duplicate_rows_found > 0 && (
                <span className="text-amber-600">Duplicates removed: {parseResult.metadata.duplicate_rows_found}</span>
              )}
            </div>
          )}
        </div>
      )}

      <div className="flex justify-between items-center mb-3">
        <div className="text-sm text-muted-foreground">
          Edit programme items before confirming. Changes will generate tasks.
        </div>
        <Button type="button" variant="outline" size="sm" onClick={addProgrammeItem}>
          <Plus className="mr-2 h-4 w-4" />
          Add Item
        </Button>
      </div>

      <ScrollArea className="h-[450px]">
        {(programmeItems?.length > 0 ? programmeItems : (analysis?.proposed_programme || [])).length > 0 ? (
          <table className="w-full text-sm">
            <thead className="sticky top-0 bg-card z-10">
              <tr className="border-b">
                <th className="text-left p-2 w-10">#</th>
                <th className="text-left p-2 min-w-[180px]">Task Name</th>
                <th className="text-left p-2 w-28">Phase</th>
                <th className="text-left p-2 w-28">Trade</th>
                <th className="text-left p-2 w-28">Start</th>
                <th className="text-left p-2 w-28">Finish</th>
                <th className="text-left p-2 w-16">Days</th>
                <th className="text-left p-2 w-32">Predecessor</th>
                <th className="text-left p-2 w-28">Task Code</th>
                <th className="text-left p-2 w-16">Crew</th>
                <th className="w-10"></th>
              </tr>
            </thead>
            <tbody>
            {(programmeItems?.length > 0 ? programmeItems : (analysis?.proposed_programme || [])).map((item, index) => {
              // Determine if row has issues
              const hasInvalidPredecessors = item.invalid_predecessors?.length > 0;
              const hasMissingDate = !item.planned_start;
              const hasIssue = hasInvalidPredecessors || hasMissingDate;
              
              return (
              <tr key={index} className={`border-b hover:bg-muted/50 group ${hasIssue ? 'bg-amber-50/50 dark:bg-amber-950/10' : ''}`}>
                <td className="p-2 font-mono text-muted-foreground">
                  <div className="flex items-center gap-1">
                    {hasIssue && <AlertCircle className="h-3 w-3 text-amber-500" title={hasInvalidPredecessors ? `Invalid predecessors: ${item.invalid_predecessors.join(', ')}` : 'Missing start date'} />}
                    {index + 1}
                  </div>
                </td>
                <td className="p-2">
                  <Input
                    value={item.name || ""}
                    onChange={(e) => updateProgrammeField(index, "name", e.target.value)}
                    placeholder="Task name"
                    className="h-8"
                  />
                </td>
                <td className="p-2">
                  <select
                    value={item.phase || ""}
                    onChange={(e) => updateProgrammeField(index, "phase", e.target.value)}
                    className="h-8 w-full rounded-md border border-input bg-background px-2 text-sm"
                  >
                    <option value="">Phase</option>
                    <option value="Preliminaries">Preliminaries</option>
                    <option value="Construction">Construction</option>
                    <option value="Finishing">Finishing</option>
                    <option value="Handover">Handover</option>
                  </select>
                </td>
                <td className="p-2">
                  <select
                    value={item.trade || ""}
                    onChange={(e) => updateProgrammeField(index, "trade", e.target.value)}
                    className="h-8 w-full rounded-md border border-input bg-background px-2 text-sm"
                  >
                    <option value="">Trade</option>
                    <option value="Framing">Framing</option>
                    <option value="Linings">Linings</option>
                    <option value="Stopping">Stopping</option>
                    <option value="Ceilings">Ceilings</option>
                    <option value="Insulation">Insulation</option>
                    <option value="Aluminium">Aluminium</option>
                    <option value="General">General</option>
                    <option value="Site">Site</option>
                  </select>
                </td>
                <td className="p-2">
                  <Input
                    type="date"
                    value={item.planned_start || ""}
                    onChange={(e) => {
                      updateProgrammeField(index, "planned_start", e.target.value);
                      if (e.target.value && item.duration) {
                        const start = new Date(e.target.value);
                        const finish = new Date(start);
                        finish.setDate(finish.getDate() + (parseInt(item.duration) - 1));
                        updateProgrammeField(index, "planned_finish", finish.toISOString().split('T')[0]);
                      }
                    }}
                    className="h-8 w-28"
                  />
                </td>
                <td className="p-2">
                  <Input
                    type="date"
                    value={item.planned_finish || ""}
                    onChange={(e) => updateProgrammeField(index, "planned_finish", e.target.value)}
                    className="h-8 w-28"
                  />
                </td>
                <td className="p-2">
                  <Input
                    type="number"
                    min="1"
                    value={item.duration ?? ""}
                    onChange={(e) => {
                      const dur = parseInt(e.target.value) || 1;
                      updateProgrammeField(index, "duration", dur);
                      if (item.planned_start) {
                        const start = new Date(item.planned_start);
                        const finish = new Date(start);
                        finish.setDate(finish.getDate() + (dur - 1));
                        updateProgrammeField(index, "planned_finish", finish.toISOString().split('T')[0]);
                      }
                    }}
                    className="h-8 w-16"
                  />
                </td>
                <td className="p-2">
                  <select
                    value={Array.isArray(item.depends_on) ? item.depends_on[0] || "" : ""}
                    onChange={(e) => updateProgrammeField(index, "depends_on", e.target.value ? [e.target.value] : [])}
                    className="h-8 w-full rounded-md border border-input bg-background px-2 text-sm"
                  >
                    <option value="">None</option>
                    {(programmeItems?.length > 0 ? programmeItems : (analysis?.proposed_programme || [])).slice(0, index).map((pred, predIdx) => (
                      <option key={predIdx} value={pred.id || `prog-${String(predIdx + 1).padStart(3, '0')}`}>
                        {pred.name || `#${predIdx + 1}`}
                      </option>
                    ))}
                  </select>
                </td>
                <td className="p-2">
                  <select
                    value={item.task_code_id || ""}
                    onChange={(e) => updateProgrammeField(index, "task_code_id", e.target.value || null)}
                    className="h-8 w-full rounded-md border border-input bg-background px-2 text-sm"
                  >
                    <option value="">Code</option>
                    {jobTaskCodes.map((tc) => (
                      <option key={tc.id} value={tc.id}>{tc.code}</option>
                    ))}
                  </select>
                </td>
                <td className="p-2">
                  <Input
                    type="number"
                    min="1"
                    step="0.5"
                    value={item.crew_size ?? ""}
                    onChange={(e) => updateProgrammeField(index, "crew_size", parseFloat(e.target.value) || null)}
                    placeholder="â€”"
                    className="h-8 w-16"
                  />
                </td>
                <td className="p-2">
                  <Button
                    type="button"
                    variant="ghost"
                    size="sm"
                    onClick={() => removeProgrammeItem(index)}
                    className="opacity-0 group-hover:opacity-100 h-8 w-8 p-0"
                  >
                    <Trash2 className="h-4 w-4 text-destructive" />
                  </Button>
                </td>
              </tr>
            );
            })}
            </tbody>
          </table>
        ) : (
          <div className="text-center py-8">
            <p className="text-muted-foreground mb-2">
              No programme generated
            </p>
            <Button type="button" variant="outline" size="sm" onClick={addProgrammeItem}>
              <Plus className="mr-2 h-4 w-4" />
              Add First Item
            </Button>
          </div>
        )}
      </ScrollArea>
    </CardContent>
  </Card>
</TabsContent>
          </Tabs>

          <div className="flex justify-between">
            <Button variant="outline" onClick={() => goToStep(2)} disabled={analyzing}>
              <ArrowLeft className="mr-2 h-4 w-4" />
              Re-analyze
            </Button>
            <Button onClick={handleConfirm} disabled={loading} data-testid="confirm-setup-btn">
              {loading && <Loader2 className="mr-2 h-4 w-4 animate-spin" />}
              <Check className="mr-2 h-4 w-4" />
              Confirm & Save
            </Button>
          </div>
        </div>
      )}
    </div>
  );
}











































































