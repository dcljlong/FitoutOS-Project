import React, { useState, useEffect, useCallback } from 'react';

import { useParams, useNavigate, Link, useSearchParams } from 'react-router-dom';
import api from '@/lib/api';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Checkbox } from '@/components/ui/checkbox';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { ScrollArea } from '@/components/ui/scroll-area';
import { Separator } from '@/components/ui/separator';
import {
  ArrowLeft,
  ArrowRight,
  Upload,
  FileText,
  FileSpreadsheet,
  Sparkles,
  Check,
  X,
  Edit,
  Trash2,
  Plus,
  Loader2,
  AlertCircle,
  CheckCircle,
  Info,
} from 'lucide-react';
import { toast } from 'sonner';
const getErrorMessage = (error, fallback) => {
  if (typeof error?.response?.data?.detail === "string") return error.response.data.detail;
  if (Array.isArray(error?.response?.data?.detail) && error?.response?.data?.detail?.[0]?.msg) {
    return error.response.data.detail[0].msg;
  }
  return fallback;
};


import { useDropzone } from 'react-dropzone';

// Step indicator component
const StepIndicator = ({ steps, currentStep }) => (
  <div className="flex items-center justify-center gap-2 mb-8">
    {steps.map((step, index) => (
      <React.Fragment key={step.id}>
        <div className={`flex items-center gap-2 ${index <= currentStep ? 'text-primary' : 'text-muted-foreground'}`}>
          <div className={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-medium border-2 
            ${index < currentStep ? 'bg-primary text-primary-foreground border-primary' : 
              index === currentStep ? 'border-primary' : 'border-muted'}`}>
            {index < currentStep ? <Check className="h-4 w-4" /> : index + 1}
          </div>
          <span className="hidden md:inline text-sm font-medium">{step.label}</span>
        </div>
        {index < steps.length - 1 && (
          <div className={`w-12 h-0.5 ${index < currentStep ? 'bg-primary' : 'bg-muted'}`} />
        )}
      </React.Fragment>
    ))}
  </div>
);

// Confidence badge component
const ConfidenceBadge = ({ level }) => {
  const colors = {
    high: 'bg-green-100 text-green-700 border-green-200',
    medium: 'bg-amber-100 text-amber-700 border-amber-200',
    low: 'bg-red-100 text-red-700 border-red-200',
  };
  return (
    <span className={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium border ${colors[level] || colors.medium}`}>
      {level}
    </span>
  );
};

export default function JobSetupPage() {
  const handleDeleteFile = async (fileId) => {
    if (!window.confirm("Delete this file?")) return;
    const targetJobId = jobId || job?.id;
    if (!targetJobId) return;

    try {
      await api.delete(`/jobs/${targetJobId}/files/${fileId}`);
      setFiles((prev) => prev.filter(f => (f._id || f.id || f.file_id) !== fileId));
      toast.success('File deleted');
    } catch (error) {
      toast.error(error.response?.data?.detail || 'Failed to delete file');
    }
  };

  const { jobId } = useParams();
  const [searchParams, setSearchParams] = useSearchParams();
  const navigate = useNavigate();

  const goToStep = (step) => {
    const parsed = Number(step);
    if (!isNaN(parsed) && parsed >= 0 && parsed <= 3) {
      setCurrentStep(parsed);
      setSearchParams({ step: String(parsed) });
    }
  };
  const [currentStep, setCurrentStep] = useState(0);
  useEffect(() => {
    const step = searchParams.get("step");
    if (step !== null) {
      const parsed = Number(step);
      if (!isNaN(parsed) && parsed >= 0 && parsed <= 3) {
        setCurrentStep(parsed);
      }
    }
  }, [searchParams]);
  const [loading, setLoading] = useState(false);
  const [analyzing, setAnalyzing] = useState(false);
  const [parsing, setParsing] = useState(false);
  
  // Job data
  const [job, setJob] = useState(null);
  const [files, setFiles] = useState([]);
  const [analysis, setAnalysis] = useState(null);
  const [parseResult, setParseResult] = useState(null); // Stores parse warnings/errors
const [jobTaskCodes, setJobTaskCodes] = useState([]);
  const [programmeItems, setProgrammeItems] = useState([]);
  const updateProgrammeField = (index, field, value) => {
    const updated = [...programmeItems];
    updated[index] = { ...updated[index], [field]: value };
    setProgrammeItems(updated);
  };

  const removeProgrammeItem = (index) => {
    const updated = programmeItems.filter((_, i) => i !== index);
    setProgrammeItems(updated);
  };

  const addProgrammeItem = () => {
    // Calculate default start date based on last item or job start
    let defaultStart = jobForm.planned_start || new Date().toISOString().split('T')[0];
    if (programmeItems.length > 0) {
      const lastItem = programmeItems[programmeItems.length - 1];
      if (lastItem.planned_finish) {
        const lastFinish = new Date(lastItem.planned_finish);
        lastFinish.setDate(lastFinish.getDate() + 1);
        defaultStart = lastFinish.toISOString().split('T')[0];
      } else if (lastItem.planned_start && lastItem.duration) {
        const lastStart = new Date(lastItem.planned_start);
        lastStart.setDate(lastStart.getDate() + (lastItem.duration || 1));
        defaultStart = lastStart.toISOString().split('T')[0];
      }
    }
    
    const newItem = {
      id: "prog-" + (programmeItems.length + 1).toString().padStart(3, "0"),
      name: "",
      phase: "Construction",
      trade: "General",
      duration: 1,
      duration_unit: "days",
      planned_start: defaultStart,
      planned_finish: defaultStart,
      depends_on: [],
      task_code_id: null,
      crew_size: null,
      hours_per_day: 8,
      confidence: "manual"
    };
    setProgrammeItems([...programmeItems, newItem]);
  };
  
  // Form data for new job
  const [jobForm, setJobForm] = useState({
    job_number: '',
    job_name: '',
    main_contractor: '',
    site_address: '',
    planned_start: '',
    planned_finish: '',
    max_crew: '',
    standard_crew: '',
    allow_saturday: false,
    allow_overtime: false,
  });

  // Confirmed data for saving
  const [confirmedData, setConfirmedData] = useState({
    task_codes: [],
    tasks: [],
    scope_items: [],
  });

  const steps = [
    { id: 'basic', label: 'Basic Info' },
    { id: 'upload', label: 'Upload Files' },
    { id: 'analyze', label: 'AI Analysis' },
    { id: 'review', label: 'Review & Confirm' },
  ];


  const fetchJob = useCallback(async () => {
    const hasStepOverride = searchParams.get("step") !== null;
    try {
      const response = await api.get(`/jobs/${jobId}`);
      setJob(response.data);

try {
  const codesRes = await api.get(`/jobs/${response.data.id}/task-codes`);
  setJobTaskCodes(codesRes.data || []);
} catch (e) {}
      setJobForm(response.data);
      if (!hasStepOverride) goToStep(1); // Skip to upload if job exists
      
      // Check for existing files
      const filesRes = await api.get(`/jobs/${jobId}/files`);
      if (filesRes.data.length > 0) {
        setFiles(filesRes.data);
      }

      // Check for existing analysis
      if (response.data.latest_analysis) {
        setAnalysis(response.data.latest_analysis); setProgrammeItems(response.data.latest_analysis.proposed_programme || []); if (!hasStepOverride) goToStep(3); // Stay on upload step
      } else {
        try {
          const analysisRes = await api.get(`/jobs/${jobId}/analysis`);
          if (analysisRes.data) {
            setAnalysis(analysisRes.data.analysis); setProgrammeItems(analysisRes.data.analysis.proposed_programme || []); if (!hasStepOverride) goToStep(3); // Stay on upload step
          }
        } catch (e) {
          // No analysis yet
        }
      }
    } catch (error) {
      toast.error(getErrorMessage(error, 'Failed to load job'));
    }

  }, [jobId, searchParams]);


  useEffect(() => {
    if (jobId) {
      fetchJob();
    }
  }, [fetchJob, jobId]);

  useEffect(() => {
    if (analysis?.proposed_programme?.length > 0) {
      setProgrammeItems(analysis.proposed_programme);
    } else {
      setProgrammeItems([]);
    }
  }, [analysis]);

  // File upload handling
  const onDrop = useCallback(async (acceptedFiles) => {
    if (!job && !jobId) {
      toast.error('Please create the job first');
      return;
    }
    
    const targetJobId = jobId || job?.id;
    const formData = new FormData();
    acceptedFiles.forEach(file => {
      formData.append('files', file);
    });

    try {
      setLoading(true);
      const response = await api.post(`/jobs/${targetJobId}/upload`, formData, {
        headers: { 'Content-Type': 'multipart/form-data' },
      });
      setFiles([...files, ...response.data.files]);
      toast.success(`Uploaded ${response.data.files.length} file(s)`);
    } catch (error) {
      toast.error(getErrorMessage(error, 'Failed to upload files'));
    } finally {
      setLoading(false);
    }
  }, [job, jobId, files]);

  const { getRootProps, getInputProps, isDragActive } = useDropzone({
    onDrop,
    accept: {
      'application/pdf': ['.pdf'],
      'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet': ['.xlsx'],
      'application/vnd.ms-excel': ['.xls'],
      'text/csv': ['.csv'],
    },
  });

  // Create job
  const handleCreateJob = async () => {
  try {
    setLoading(true);

    const payload = {
      job_number: (jobForm.job_number || '').trim(),
      job_name: (jobForm.job_name || '').trim(),
      main_contractor: (jobForm.main_contractor || '').trim() || null,
      site_address: (jobForm.site_address || '').trim() || null,
      planned_start: jobForm.planned_start || null,
      planned_finish: jobForm.planned_finish || null,
      max_crew: jobForm.max_crew === '' ? null : Number(jobForm.max_crew),
      standard_crew: jobForm.standard_crew === '' ? null : Number(jobForm.standard_crew),
      allow_saturday: !!jobForm.allow_saturday,
      allow_overtime: !!jobForm.allow_overtime,
    };

    const response = await api.post('/jobs', payload);
    setJob(response.data);

try {
  const codesRes = await api.get(`/jobs/${response.data.id}/task-codes`);
  setJobTaskCodes(codesRes.data || []);
} catch (e) {}
    toast.success('Job created');
    navigate(`/jobs/${response.data.id}/setup`);
  } catch (error) {
    const message =
      error?.response?.data?.detail
        ? (Array.isArray(error.response.data.detail)
            ? error.response.data.detail.map(d => d.msg || JSON.stringify(d)).join(', ')
            : String(error.response.data.detail))
        : 'Failed to create job';

    console.error('Create job failed:', error);
    toast.error(message);
  } finally {
    setLoading(false);
  }
};

  // Run AI analysis
  const handleAnalyze = async () => {
    const targetJobId = jobId || job?.id;
    if (!targetJobId) return;

    setAnalyzing(true);
    try {
      const analyzeRes = await api.post(`/jobs/${targetJobId}/analyze`);

      const savedAnalysis = analyzeRes.data?.analysis || analyzeRes.data || (await api.get(`/jobs/${targetJobId}/analysis`)).data;

      const hasUsableAnalysis = !!(
        savedAnalysis && (
          (jobTaskCodes.length ? jobTaskCodes : savedAnalysis?.proposed_task_codes)?.length ||
          savedAnalysis.proposed_tasks?.length ||
          savedAnalysis.scope_items?.length ||
          savedAnalysis.proposed_programme?.length
        )
      );

      if (!hasUsableAnalysis) {
        toast.error('Analysis completed but no usable data was returned.');
        return;
      }


      setAnalysis(savedAnalysis);
      setProgrammeItems(savedAnalysis?.proposed_programme || []);

      setConfirmedData({
        task_codes: jobTaskCodes.length ? jobTaskCodes : (savedAnalysis?.proposed_task_codes || []),
        tasks: savedAnalysis?.proposed_tasks || [],
        scope_items: savedAnalysis?.scope_items || [],
      });

      goToStep(3);
      toast.success('Analysis complete! Review the results.');
    } catch (error) {
      toast.error(getErrorMessage(error, 'Analysis failed'));
    } finally {
      setAnalyzing(false);
    }
  };

  // Parse programme file (structured parsing without AI)
  const handleParseProgramme = async (fileId = null) => {
    const targetJobId = jobId || job?.id;
    if (!targetJobId) return;

    setParsing(true);
    try {
      const url = fileId 
        ? `/jobs/${targetJobId}/parse-programme?file_id=${fileId}`
        : `/jobs/${targetJobId}/parse-programme`;
      
      const parseRes = await api.post(url);
      const data = parseRes.data;
      
      if (!data.success || data.item_count === 0) {
        toast.error(data.errors?.[0]?.message || 'No programme items found in file');
        return;
      }

      // Store parse result for warnings display
      setParseResult({
        filename: data.filename,
        warnings: data.warnings || [],
        errors: data.errors || [],
        metadata: data.metadata || {},
      });

      // Set programme items from parsed data
      setProgrammeItems(data.items || []);
      
      // Create a minimal analysis object for compatibility
      setAnalysis({
        job_summary: `Parsed from ${data.filename}`,
        proposed_programme: data.items,
        scope_items: [],
        proposed_tasks: [],
        proposed_task_codes: [],
      });

      goToStep(3);
      
      if (data.warning_count > 0) {
        toast.warning(`Parsed ${data.item_count} items with ${data.warning_count} warnings. Review below.`);
      } else {
        toast.success(`Successfully parsed ${data.item_count} programme items!`);
      }
    } catch (error) {
      toast.error(getErrorMessage(error, 'Failed to parse programme file'));
    } finally {
      setParsing(false);
    }
  };

  // Confirm and save analysis
  const handleConfirm = async () => {
    const targetJobId = jobId || job?.id;
    if (!targetJobId) return;
    
    setLoading(true);
    try {
      const payload = {
  task_codes: confirmedData.task_codes?.length ? confirmedData.task_codes : (jobTaskCodes.length ? jobTaskCodes : (analysis?.proposed_task_codes || [])),
  tasks: confirmedData.tasks?.length ? confirmedData.tasks : (analysis?.proposed_tasks || []),
  scope_items: confirmedData.scope_items?.length ? confirmedData.scope_items : (analysis?.scope_items || []),
  programme: programmeItems
};
      await api.post(`/jobs/${targetJobId}/analysis/confirm`, payload);
      toast.success('Job setup complete!');
      navigate(`/jobs/${targetJobId}`);
    } catch (error) {
      toast.error(getErrorMessage(error, 'Failed to save setup'));
    } finally {
      setLoading(false);
    }
  };

  // Toggle item selection
  const toggleItem = (type, item, selected) => {
    setConfirmedData(prev => ({
      ...prev,
      [type]: selected 
        ? [...prev[type], item]
        : prev[type].filter(i => i !== item),
    }));
  };

  return (
    <div className="max-w-4xl mx-auto space-y-6" data-testid="job-setup-page">
      {/* Header */}
      <div className="flex items-center gap-4">
        <Link to={jobId ? `/jobs/${jobId}` : '/jobs'}>
          <Button variant="ghost" size="icon">
            <ArrowLeft className="h-5 w-5" />
          </Button>
        </Link>
        <div>
          <h1 className="text-2xl font-bold font-['Manrope']">
            {jobId ? 'Job Setup' : 'New Job Setup'}
          </h1>
          <p className="text-muted-foreground">
            {job ? `${job.job_number} - ${job.job_name}` : 'Create and configure a new job'}
          </p>
        </div>
      </div>

      {/* Step Indicator */}
      <StepIndicator steps={steps} currentStep={currentStep} />

      {/* Step Content */}
      {currentStep === 0 && (
        <Card>
          <CardHeader>
            <CardTitle>Basic Job Information</CardTitle>
            <CardDescription>Enter the core details for this job</CardDescription>
          </CardHeader>
          <CardContent className="space-y-4">
            <div className="grid gap-4 md:grid-cols-2">
              <div className="space-y-2">
                <Label htmlFor="job_number">Job Number *</Label>
                <Input
                  id="job_number"
                  value={jobForm.job_number}
                  onChange={(e) => setJobForm({ ...jobForm, job_number: e.target.value })}
                  placeholder="e.g. 2024-001"
                  data-testid="setup-job-number"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="job_name">Job Name *</Label>
                <Input
                  id="job_name"
                  value={jobForm.job_name}
                  onChange={(e) => setJobForm({ ...jobForm, job_name: e.target.value })}
                  placeholder="e.g. ABC Office Fitout"
                  data-testid="setup-job-name"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="main_contractor">Main Contractor</Label>
                <Input
                  id="main_contractor"
                  value={jobForm.main_contractor}
                  onChange={(e) => setJobForm({ ...jobForm, main_contractor: e.target.value })}
                  placeholder="e.g. Fletcher Construction"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="site_address">Site Address</Label>
                <Input
                  id="site_address"
                  value={jobForm.site_address}
                  onChange={(e) => setJobForm({ ...jobForm, site_address: e.target.value })}
                  placeholder="e.g. 123 Queen St, Auckland"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="planned_start">Planned Start</Label>
                <Input
                  id="planned_start"
                  type="date"
                  value={jobForm.planned_start}
                  onChange={(e) => setJobForm({ ...jobForm, planned_start: e.target.value })}
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="planned_finish">Planned Finish</Label>
                <Input
                  id="planned_finish"
                  type="date"
                  value={jobForm.planned_finish}
                  onChange={(e) => setJobForm({ ...jobForm, planned_finish: e.target.value })}
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="standard_crew">Standard Crew</Label>
                <Input
                  id="standard_crew"
                  type="number"
                  min="0"
                  step="0.5"
                  value={jobForm.standard_crew}
                  onChange={(e) => setJobForm({ ...jobForm, standard_crew: e.target.value })}
                  placeholder="e.g. 4"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="max_crew">Max Crew</Label>
                <Input
                  id="max_crew"
                  type="number"
                  min="0"
                  step="0.5"
                  value={jobForm.max_crew}
                  onChange={(e) => setJobForm({ ...jobForm, max_crew: e.target.value })}
                  placeholder="e.g. 6"
                />
              </div>
              <div className="space-y-2 rounded-md border p-3">
                <Label htmlFor="allow_saturday" className="cursor-pointer">Allow Saturday</Label>
                <input
                  id="allow_saturday"
                  type="checkbox"
                  checked={jobForm.allow_saturday}
                  onChange={(e) => setJobForm({ ...jobForm, allow_saturday: e.target.checked })}
                  className="mt-2 h-4 w-4"
                />
              </div>
              <div className="space-y-2 rounded-md border p-3">
                <Label htmlFor="allow_overtime" className="cursor-pointer">Allow Overtime</Label>
                <input
                  id="allow_overtime"
                  type="checkbox"
                  checked={jobForm.allow_overtime}
                  onChange={(e) => setJobForm({ ...jobForm, allow_overtime: e.target.checked })}
                  className="mt-2 h-4 w-4"
                />
              </div>
            </div>
            
            <div className="flex justify-end pt-4">
              <Button onClick={handleCreateJob} disabled={loading} data-testid="create-job-btn">
                {loading && <Loader2 className="mr-2 h-4 w-4 animate-spin" />}
                Create Job & Continue
                <ArrowRight className="ml-2 h-4 w-4" />
              </Button>
            </div>
          </CardContent>
        </Card>
      )}

      {currentStep === 1 && (
        <Card>
          <CardHeader>
            <CardTitle>Upload Documents</CardTitle>
            <CardDescription>
              Upload your quote/scope Excel files and main contractor programme PDFs
            </CardDescription>
          </CardHeader>
          <CardContent className="space-y-4">
            <div
              {...getRootProps()}
              className={`upload-zone cursor-pointer ${isDragActive ? 'dragging' : ''}`}
              data-testid="file-dropzone"
            >
              <input {...getInputProps()} />
              <Upload className="h-12 w-12 text-muted-foreground" />
              <div className="text-center">
                <p className="font-medium">
                  {isDragActive ? 'Drop files here' : 'Drag & drop files here'}
                </p>
                <p className="text-sm text-muted-foreground mt-1">
                  or click to browse (PDF, Excel, CSV)
                </p>
              </div>
            </div>

            {files.length > 0 && (
              <div className="space-y-2">
                <h3 className="font-medium">Uploaded Files</h3>
                {files.map((file, index) => (
                  <div key={index} className="flex items-center gap-3 p-3 rounded-lg border">
                    
  {file.filename?.endsWith('.pdf') ? (
                      <FileText className="h-5 w-5 text-red-500" />
                    ) : (
                      <FileSpreadsheet className="h-5 w-5 text-green-500" />
                    )}
                    <span className="flex-1 truncate">{file.filename}</span>
                    <CheckCircle className="h-5 w-5 text-green-500" />
                    <Button
                      type="button"
                      variant="ghost"
                      size="sm"
                      onClick={() => handleDeleteFile(file._id || file.id || file.file_id)}
                      title="Delete file"
                      className="text-red-500 hover:text-red-600"
                    >
                      <Trash2 className="h-4 w-4" />
                    </Button>
                  </div>
                ))}
              </div>
            )}

            <div className="flex justify-between pt-4">
              <Button variant="outline" onClick={() => goToStep(0)} disabled={analyzing}>
                <ArrowLeft className="mr-2 h-4 w-4" />
                Back
              </Button>
              <Button onClick={() => goToStep(2)} data-testid="continue-to-analyze" disabled={analyzing}>
                Continue to Analysis
                <ArrowRight className="ml-2 h-4 w-4" />
              </Button>
            </div>
          </CardContent>
        </Card>
      )}

      {currentStep === 2 && (
        <Card>
          <CardHeader>
            <CardTitle className="flex items-center gap-2">
              <FileSpreadsheet className="h-5 w-5 text-primary" />
              Process Programme Files
            </CardTitle>
            <CardDescription>
              Parse your Excel/CSV programme files or use AI to analyze all documents
            </CardDescription>
          </CardHeader>
          <CardContent className="space-y-6">
            {/* Programme File Parsing Option */}
            {files.some(f => f.filename?.match(/\.(xlsx|xls|csv)$/i)) && (
              <div className="bg-green-50 dark:bg-green-950/20 border border-green-200 dark:border-green-800 rounded-lg p-6">
                <div className="flex items-start gap-4">
                  <FileSpreadsheet className="h-10 w-10 text-green-600 flex-shrink-0" />
                  <div className="flex-1">
                    <h3 className="text-lg font-medium text-green-800 dark:text-green-200 mb-2">
                      Parse Programme File (Recommended)
                    </h3>
                    <p className="text-sm text-green-700 dark:text-green-300 mb-3">
                      Directly parse your Excel/CSV programme file for accurate dates, tasks, and dependencies.
                      Handles various formats including contractor exports.
                    </p>
                    <div className="space-y-2 mb-4">
                      {files.filter(f => f.filename?.match(/\.(xlsx|xls|csv)$/i)).map((file, idx) => (
                        <div key={idx} className="flex items-center gap-2 text-sm">
                          <FileSpreadsheet className="h-4 w-4 text-green-600" />
                          <span className="text-green-800 dark:text-green-200">{file.filename}</span>
                          <Button
                            size="sm"
                            variant="outline"
                            className="ml-auto h-7 text-xs border-green-300 text-green-700 hover:bg-green-100"
                            onClick={() => handleParseProgramme(file.id || file._id)}
                            disabled={parsing || analyzing}
                            data-testid={`parse-file-${idx}`}
                          >
