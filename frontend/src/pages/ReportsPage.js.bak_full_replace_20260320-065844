import React, { useState, useEffect, useCallback } from 'react';
import api from '@/lib/api';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from '@/components/ui/select';
import {
  BarChart,
  Bar,
  XAxis,
  YAxis,
  CartesianGrid,
  Tooltip,
  ResponsiveContainer,
  PieChart,
  Pie,
  Cell,
  Legend,
} from 'recharts';
import {
  BarChart3,
  PieChart as PieChartIcon,
  TrendingUp,
  Clock,
  Briefcase,
  Loader2,
  Filter,
} from 'lucide-react';
import { toast } from 'sonner';

const COLORS = ['#0033CC', '#3B82F6', '#60A5FA', '#93C5FD', '#BFDBFE', '#DBEAFE'];

export default function ReportsPage() {
  const [hoursByJob, setHoursByJob] = useState([]);
  const [hoursByCode, setHoursByCode] = useState([]);
  const [jobs, setJobs] = useState([]);
  const [selectedJob, setSelectedJob] = useState('all');
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    fetchData();
  }, [selectedJob]);

  async function fetchData() {
    setLoading(true);
    try {
      const codeUrl = selectedJob === 'all'
        ? '/reports/hours-by-code'
        : "/reports/hours-by-code?job_id=${selectedJob}";

      const [jobsRes, hoursByJobRes, hoursByCodeRes] = await Promise.all([
        api.get('/jobs'),
        api.get('/reports/hours-by-job'),
        api.get(codeUrl)
      ]);

      setJobs(jobsRes.data || []);
      setHoursByJob(hoursByJobRes.data || []);
      setHoursByCode(hoursByCodeRes.data || []);
    } catch (error) {
      console.error('Reports load failed:', error);
      toast.error('Failed to load reports data');
    } finally {
      setLoading(false);
    }
  }
  }

  // Calculate totals
  const totalQuoted = hoursByJob.reduce((sum, j) => sum + (j.quoted_hours || 0), 0);
  const totalActual = hoursByJob.reduce((sum, j) => sum + j.total_hours, 0);
  const totalVariance = totalActual - totalQuoted;

  // Prepare chart data
  const jobChartData = hoursByJob
    .filter(j => j.job_number)
    .slice(0, 10)
    .map(j => ({
      name: j.job_number,
      quoted: j.quoted_hours || 0,
      actual: j.total_hours,
    }));

  const codeChartData = hoursByCode
    .slice(0, 8)
    .map(c => ({
      name: c._id || 'Unknown',
      value: c.total_hours,
    }));

  if (loading) {
    return (
      <div className="flex items-center justify-center min-h-[400px]">
        <Loader2 className="h-8 w-8 animate-spin text-primary" />
      </div>
    );
  }

  return (
    <div className="space-y-6" data-testid="reports-page">
      {/* Header */}
      <div className="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h1 className="text-3xl font-bold font-['Manrope']">Reports</h1>
          <p className="text-muted-foreground mt-1">Hours tracking and variance analysis</p>
        </div>
        <div className="flex items-center gap-2">
          <Filter className="h-4 w-4 text-muted-foreground" />
          <Select value={selectedJob} onValueChange={setSelectedJob}>
            <SelectTrigger className="w-[250px]" data-testid="job-filter">
              <SelectValue placeholder="Filter by job" />
            </SelectTrigger>
            <SelectContent>
              <SelectItem value="all">All Jobs</SelectItem>
              {jobs.map((job) => (
                <SelectItem key={job.id} value={job.id}>
                  {job.job_number} - {job.job_name}
                </SelectItem>
              ))}
            </SelectContent>
          </Select>
        </div>
      </div>

      {/* Summary Cards */}
      <div className="grid gap-4 md:grid-cols-4">
        <Card>
          <CardContent className="pt-6">
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm text-muted-foreground">Total Quoted</p>
                <p className="font-data text-2xl font-bold mt-1">{totalQuoted.toFixed(1)}h</p>
              </div>
              <Clock className="h-8 w-8 text-muted-foreground/50" />
            </div>
          </CardContent>
        </Card>
        
        <Card>
          <CardContent className="pt-6">
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm text-muted-foreground">Total Actual</p>
                <p className="font-data text-2xl font-bold mt-1">{totalActual.toFixed(1)}h</p>
              </div>
              <BarChart3 className="h-8 w-8 text-muted-foreground/50" />
            </div>
          </CardContent>
        </Card>
        
        <Card className={totalVariance > 0 ? 'border-red-200' : 'border-green-200'}>
          <CardContent className="pt-6">
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm text-muted-foreground">Variance</p>
                <p className={`font-data text-2xl font-bold mt-1 ${totalVariance > 0 ? 'text-red-600' : 'text-green-600'}`}>
                  {totalVariance > 0 ? '+' : ''}{totalVariance.toFixed(1)}h
                </p>
              </div>
              <TrendingUp className={`h-8 w-8 ${totalVariance > 0 ? 'text-red-400' : 'text-green-400'}`} />
            </div>
          </CardContent>
        </Card>
        
        <Card>
          <CardContent className="pt-6">
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm text-muted-foreground">Active Jobs</p>
                <p className="font-data text-2xl font-bold mt-1">{hoursByJob.filter(j => j.job_number).length}</p>
              </div>
              <Briefcase className="h-8 w-8 text-muted-foreground/50" />
            </div>
          </CardContent>
        </Card>
      </div>

      {/* Charts */}
      <Tabs defaultValue="by-job" className="space-y-4">
        <TabsList>
          <TabsTrigger value="by-job" className="flex items-center gap-2">
            <BarChart3 className="h-4 w-4" />
            Hours by Job
          </TabsTrigger>
          <TabsTrigger value="by-code" className="flex items-center gap-2">
            <PieChartIcon className="h-4 w-4" />
            Hours by Code
          </TabsTrigger>
        </TabsList>

        <TabsContent value="by-job">
          <Card>
            <CardHeader>
              <CardTitle className="text-lg">Quoted vs Actual Hours by Job</CardTitle>
              <CardDescription>Comparison of budgeted hours against actual recorded hours</CardDescription>
            </CardHeader>
            <CardContent>
              {jobChartData.length === 0 ? (
                <div className="text-center py-12 text-muted-foreground">
                  <BarChart3 className="h-12 w-12 mx-auto mb-4 opacity-50" />
                  <p>No data available yet</p>
                </div>
              ) : (
                <div className="h-[400px]">
                  <ResponsiveContainer width="100%" height="100%">
                    <BarChart data={jobChartData} margin={{ top: 20, right: 30, left: 20, bottom: 60 }}>
                      <CartesianGrid strokeDasharray="3 3" className="stroke-border" />
                      <XAxis 
                        dataKey="name" 
                        angle={-45} 
                        textAnchor="end" 
                        height={60}
                        className="text-xs fill-muted-foreground"
                      />
                      <YAxis className="text-xs fill-muted-foreground" />
                      <Tooltip 
                        contentStyle={{ 
                          backgroundColor: 'hsl(var(--card))', 
                          border: '1px solid hsl(var(--border))',
                          borderRadius: '8px',
                        }}
                      />
                      <Legend />
                      <Bar dataKey="quoted" name="Quoted Hours" fill="#93C5FD" radius={[4, 4, 0, 0]} />
                      <Bar dataKey="actual" name="Actual Hours" fill="#0033CC" radius={[4, 4, 0, 0]} />
                    </BarChart>
                  </ResponsiveContainer>
                </div>
              )}
            </CardContent>
          </Card>
        </TabsContent>

        <TabsContent value="by-code">
          <Card>
            <CardHeader>
              <CardTitle className="text-lg">Hours Distribution by Task Code</CardTitle>
              <CardDescription>Breakdown of time spent across different task codes</CardDescription>
            </CardHeader>
            <CardContent>
              {codeChartData.length === 0 ? (
                <div className="text-center py-12 text-muted-foreground">
                  <PieChartIcon className="h-12 w-12 mx-auto mb-4 opacity-50" />
                  <p>No data available yet</p>
                </div>
              ) : (
                <div className="h-[400px]">
                  <ResponsiveContainer width="100%" height="100%">
                    <PieChart>
                      <Pie
                        data={codeChartData}
                        cx="50%"
                        cy="50%"
                        labelLine={false}
                        label={({ name, percent }) => `${name} (${(percent * 100).toFixed(0)}%)`}
                        outerRadius={150}
                        fill="#8884d8"
                        dataKey="value"
                      >
                        {codeChartData.map((entry, index) => (
                          <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />
                        ))}
                      </Pie>
                      <Tooltip 
                        contentStyle={{ 
                          backgroundColor: 'hsl(var(--card))', 
                          border: '1px solid hsl(var(--border))',
                          borderRadius: '8px',
                        }}
                        formatter={(value) => [`${value.toFixed(1)}h`, 'Hours']}
                      />
                      <Legend />
                    </PieChart>
                  </ResponsiveContainer>
                </div>
              )}
            </CardContent>
          </Card>
        </TabsContent>
      </Tabs>

      {/* Detailed Table */}
      <Card>
        <CardHeader>
          <CardTitle className="text-lg">Job Hours Summary</CardTitle>
          <CardDescription>Detailed breakdown by job</CardDescription>
        </CardHeader>
        <CardContent>
          <div className="overflow-x-auto">
            <table className="data-table">
              <thead>
                <tr>
                  <th>Job</th>
                  <th>Name</th>
                  <th className="text-right">Quoted</th>
                  <th className="text-right">Actual</th>
                  <th className="text-right">Variance</th>
                  <th className="text-right">%</th>
                </tr>
              </thead>
              <tbody>
                {hoursByJob.filter(j => j.job_number).map((job) => {
                  const variance = job.total_hours - (job.quoted_hours || 0);
                  const percent = job.quoted_hours ? (job.total_hours / job.quoted_hours * 100) : 0;
                  
                  return (
                    <tr key={job._id}>
                      <td className="font-mono font-medium">{job.job_number}</td>
                      <td>{job.job_name}</td>
                      <td className="text-right font-data">{(job.quoted_hours || 0).toFixed(1)}</td>
                      <td className="text-right font-data font-bold">{job.total_hours.toFixed(1)}</td>
                      <td className={`text-right font-data ${variance > 0 ? 'text-red-600' : 'text-green-600'}`}>
                        {variance > 0 ? '+' : ''}{variance.toFixed(1)}
                      </td>
                      <td className={`text-right font-data ${percent > 100 ? 'text-red-600' : 'text-green-600'}`}>
                        {job.quoted_hours ? `${percent.toFixed(0)}%` : '-'}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
              <tfoot>
                <tr className="font-bold">
                  <td colSpan={2}>Total</td>
                  <td className="text-right font-data">{totalQuoted.toFixed(1)}</td>
                  <td className="text-right font-data">{totalActual.toFixed(1)}</td>
                  <td className={`text-right font-data ${totalVariance > 0 ? 'text-red-600' : 'text-green-600'}`}>
                    {totalVariance > 0 ? '+' : ''}{totalVariance.toFixed(1)}
                  </td>
                  <td className="text-right font-data">
                    {totalQuoted > 0 ? `${(totalActual / totalQuoted * 100).toFixed(0)}%` : '-'}
                  </td>
                </tr>
              </tfoot>
            </table>
          </div>
        </CardContent>
      </Card>
    </div>
  );
}





