import React, { useState, useEffect, useCallback } from 'react';

import { useParams, useNavigate, Link } from 'react-router-dom';
import api from '@/lib/api';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Checkbox } from '@/components/ui/checkbox';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { ScrollArea } from '@/components/ui/scroll-area';
import { Separator } from '@/components/ui/separator';
import {
  ArrowLeft,
  ArrowRight,
  Upload,
  FileText,
  FileSpreadsheet,
  Sparkles,
  Check,
  X,
  Edit,
  Trash2,
  Plus,
  Loader2,
  AlertCircle,
  CheckCircle,
  Info,
} from 'lucide-react';
import { toast } from 'sonner';
import { useDropzone } from 'react-dropzone';

// Step indicator component
const StepIndicator = ({ steps, currentStep }) => (
  <div className="flex items-center justify-center gap-2 mb-8">
    {steps.map((step, index) => (
      <React.Fragment key={step.id}>
        <div className={`flex items-center gap-2 ${index <= currentStep ? 'text-primary' : 'text-muted-foreground'}`}>
          <div className={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-medium border-2 
            ${index < currentStep ? 'bg-primary text-primary-foreground border-primary' : 
              index === currentStep ? 'border-primary' : 'border-muted'}`}>
            {index < currentStep ? <Check className="h-4 w-4" /> : index + 1}
          </div>
          <span className="hidden md:inline text-sm font-medium">{step.label}</span>
        </div>
        {index < steps.length - 1 && (
          <div className={`w-12 h-0.5 ${index < currentStep ? 'bg-primary' : 'bg-muted'}`} />
        )}
      </React.Fragment>
    ))}
  </div>
);

// Confidence badge component
const ConfidenceBadge = ({ level }) => {
  const colors = {
    high: 'bg-green-100 text-green-700 border-green-200',
    medium: 'bg-amber-100 text-amber-700 border-amber-200',
    low: 'bg-red-100 text-red-700 border-red-200',
  };
  return (
    <span className={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium border ${colors[level] || colors.medium}`}>
      {level}
    </span>
  );
};

export default function JobSetupPage() {
  const handleDeleteFile = async (fileId) => {
    const targetJobId = jobId || job?.id;
    if (!targetJobId) return;

    try {
      await api.delete(`/jobs/${targetJobId}/files/${fileId}`);
      setFiles((prev) => prev.filter(f => (f._id || f.id) !== fileId));
      toast.success('File deleted');
    } catch (error) {
      toast.error(error.response?.data?.detail || 'Failed to delete file');
    }
  };

  const { jobId } = useParams();
  const navigate = useNavigate();
  const [currentStep, setCurrentStep] = useState(0);
  const [loading, setLoading] = useState(false);
  const [analyzing, setAnalyzing] = useState(false);
  
  // Job data
  const [job, setJob] = useState(null);
  const [files, setFiles] = useState([]);
  const [analysis, setAnalysis] = useState(null);
  const [programmeItems, setProgrammeItems] = useState([]);
  const updateProgrammeField = (index, field, value) => {
    const updated = [...programmeItems];
    updated[index] = { ...updated[index], [field]: value };
    setProgrammeItems(updated);
  };

  const removeProgrammeItem = (index) => {
    const updated = programmeItems.filter((_, i) => i !== index);
    setProgrammeItems(updated);
  };

  const addProgrammeItem = () => {
    const newItem = {
      id: "prog-" + (programmeItems.length + 1).toString().padStart(3, "0"),
      name: "",
      phase: "",
      trade: "",
      duration: 1,
      duration_unit: "days",
      depends_on: [],
      confidence: "manual"
    };
    setProgrammeItems([...programmeItems, newItem]);
  };
  
  // Form data for new job
  const [jobForm, setJobForm] = useState({
    job_number: '',
    job_name: '',
    main_contractor: '',
    site_address: '',
    planned_start: '',
    planned_finish: '',
  });

  // Confirmed data for saving
  const [confirmedData, setConfirmedData] = useState({
    task_codes: [],
    tasks: [],
    scope_items: [],
  });

  const steps = [
    { id: 'basic', label: 'Basic Info' },
    { id: 'upload', label: 'Upload Files' },
    { id: 'analyze', label: 'AI Analysis' },
    { id: 'review', label: 'Review & Confirm' },
  ];

  useEffect(() => {
    if (jobId) {
      fetchJob();
    }
  }, [jobId]);

  const fetchJob = async () => {
    try {
      const response = await api.get(`/jobs/${jobId}`);
      setJob(response.data);
      setJobForm(response.data);
      setCurrentStep(1); // Skip to upload if job exists
      
      // Check for existing files
      const filesRes = await api.get(`/jobs/${jobId}/files`);
      if (filesRes.data.length > 0) {
        setFiles(filesRes.data);
      }

      // Check for existing analysis
      if (response.data.latest_analysis) {
        setAnalysis(response.data.latest_analysis); setProgrammeItems(response.data.latest_analysis.proposed_programme || []); setCurrentStep(3); // Stay on upload step
      } else {
        try {
          const analysisRes = await api.get(`/jobs/${jobId}/analysis`);
          if (analysisRes.data) {
            setAnalysis(analysisRes.data.analysis); setProgrammeItems(analysisRes.data.analysis.proposed_programme || []); setCurrentStep(3); // Stay on upload step
          }
        } catch (e) {
          // No analysis yet
        }
      }
    } catch (error) {
      toast.error('Failed to load job');
    }
  };

  useEffect(() => {
    if (analysis?.proposed_programme?.length > 0) {
      setProgrammeItems(analysis.proposed_programme);
    } else {
      setProgrammeItems([]);
    }
  }, [analysis]);

  // File upload handling
  const onDrop = useCallback(async (acceptedFiles) => {
    if (!job && !jobId) {
      toast.error('Please create the job first');
      return;
    }
    
    const targetJobId = jobId || job?.id;
    const formData = new FormData();
    acceptedFiles.forEach(file => {
      formData.append('files', file);
    });

    try {
      setLoading(true);
      const response = await api.post(`/jobs/${targetJobId}/upload`, formData, {
        headers: { 'Content-Type': 'multipart/form-data' },
      });
      setFiles([...files, ...response.data.files]);
      toast.success(`Uploaded ${response.data.files.length} file(s)`);
    } catch (error) {
      toast.error('Failed to upload files');
    } finally {
      setLoading(false);
    }
  }, [job, jobId, files]);

  const { getRootProps, getInputProps, isDragActive } = useDropzone({
    onDrop,
    accept: {
      'application/pdf': ['.pdf'],
      'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet': ['.xlsx'],
      'application/vnd.ms-excel': ['.xls'],
      'text/csv': ['.csv'],
    },
  });

  // Create job
  const handleCreateJob = async () => {
    if (!jobForm.job_number || !jobForm.job_name) {
      toast.error('Job number and name are required');
      return;
    }
    
    setLoading(true);
    try {
      const response = await api.post('/jobs', jobForm);
      setJob(response.data);
      navigate(`/jobs/${response.data.id}/setup`, { replace: true });
      setCurrentStep(1);
      toast.success('Job created');
    } catch (error) {
      toast.error(error.response?.data?.detail || 'Failed to create job');
    } finally {
      setLoading(false);
    }
  };

  // Run AI analysis
  const handleAnalyze = async () => {
    const targetJobId = jobId || job?.id;
    if (!targetJobId) return;
    
    setAnalyzing(true);
    try {
      const response = await api.post(`/jobs/${targetJobId}/analyze`);
      setAnalysis(response.data.analysis);
      
      // Pre-populate confirmed data
      if (response.data.analysis) {
        setConfirmedData({
          task_codes: response.data.analysis.proposed_task_codes || [],
          tasks: response.data.analysis.proposed_tasks || [],
          scope_items: response.data.analysis.scope_items || [],
        });
      }
      
      setCurrentStep(3);
      toast.success('Analysis complete! Review the results.');
    } catch (error) {
      toast.error(error.response?.data?.detail || 'Analysis failed');
    } finally {
      setAnalyzing(false);
    }
  };

  // Confirm and save analysis
  const handleConfirm = async () => {
    const targetJobId = jobId || job?.id;
    if (!targetJobId) return;
    
    setLoading(true);
    try {
      const payload = {
        ...confirmedData,
        programme: programmeItems
      };
      await api.post(`/jobs/${targetJobId}/analysis/confirm`, payload);
      toast.success('Job setup complete!');
      navigate(`/jobs/${targetJobId}`);
    } catch (error) {
      toast.error('Failed to save setup');
    } finally {
      setLoading(false);
    }
  };

  // Toggle item selection
  const toggleItem = (type, item, selected) => {
    setConfirmedData(prev => ({
      ...prev,
      [type]: selected 
        ? [...prev[type], item]
        : prev[type].filter(i => i !== item),
    }));
  };

  return (
    <div className="max-w-4xl mx-auto space-y-6" data-testid="job-setup-page">
      {/* Header */}
      <div className="flex items-center gap-4">
        <Link to={jobId ? `/jobs/${jobId}` : '/jobs'}>
          <Button variant="ghost" size="icon">
            <ArrowLeft className="h-5 w-5" />
          </Button>
        </Link>
        <div>
          <h1 className="text-2xl font-bold font-['Manrope']">
            {jobId ? 'Job Setup' : 'New Job Setup'}
          </h1>
          <p className="text-muted-foreground">
            {job ? `${job.job_number} - ${job.job_name}` : 'Create and configure a new job'}
          </p>
        </div>
      </div>

      {/* Step Indicator */}
      <StepIndicator steps={steps} currentStep={currentStep} />

      {/* Step Content */}
      {currentStep === 0 && (
        <Card>
          <CardHeader>
            <CardTitle>Basic Job Information</CardTitle>
            <CardDescription>Enter the core details for this job</CardDescription>
          </CardHeader>
          <CardContent className="space-y-4">
            <div className="grid gap-4 md:grid-cols-2">
              <div className="space-y-2">
                <Label htmlFor="job_number">Job Number *</Label>
                <Input
                  id="job_number"
                  value={jobForm.job_number}
                  onChange={(e) => setJobForm({ ...jobForm, job_number: e.target.value })}
                  placeholder="e.g. 2024-001"
                  data-testid="setup-job-number"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="job_name">Job Name *</Label>
                <Input
                  id="job_name"
                  value={jobForm.job_name}
                  onChange={(e) => setJobForm({ ...jobForm, job_name: e.target.value })}
                  placeholder="e.g. ABC Office Fitout"
                  data-testid="setup-job-name"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="main_contractor">Main Contractor</Label>
                <Input
                  id="main_contractor"
                  value={jobForm.main_contractor}
                  onChange={(e) => setJobForm({ ...jobForm, main_contractor: e.target.value })}
                  placeholder="e.g. Fletcher Construction"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="site_address">Site Address</Label>
                <Input
                  id="site_address"
                  value={jobForm.site_address}
                  onChange={(e) => setJobForm({ ...jobForm, site_address: e.target.value })}
                  placeholder="e.g. 123 Queen St, Auckland"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="planned_start">Planned Start</Label>
                <Input
                  id="planned_start"
                  type="date"
                  value={jobForm.planned_start}
                  onChange={(e) => setJobForm({ ...jobForm, planned_start: e.target.value })}
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="planned_finish">Planned Finish</Label>
                <Input
                  id="planned_finish"
                  type="date"
                  value={jobForm.planned_finish}
                  onChange={(e) => setJobForm({ ...jobForm, planned_finish: e.target.value })}
                />
              </div>
            </div>
            
            <div className="flex justify-end pt-4">
              <Button onClick={handleCreateJob} disabled={loading} data-testid="create-job-btn">
                {loading && <Loader2 className="mr-2 h-4 w-4 animate-spin" />}
                Create Job & Continue
                <ArrowRight className="ml-2 h-4 w-4" />
              </Button>
            </div>
          </CardContent>
        </Card>
      )}

      {currentStep === 1 && (
        <Card>
          <CardHeader>
            <CardTitle>Upload Documents</CardTitle>
            <CardDescription>
              Upload your quote/scope Excel files and main contractor programme PDFs
            </CardDescription>
          </CardHeader>
          <CardContent className="space-y-4">
            <div
              {...getRootProps()}
              className={`upload-zone cursor-pointer ${isDragActive ? 'dragging' : ''}`}
              data-testid="file-dropzone"
            >
              <input {...getInputProps()} />
              <Upload className="h-12 w-12 text-muted-foreground" />
              <div className="text-center">
                <p className="font-medium">
                  {isDragActive ? 'Drop files here' : 'Drag & drop files here'}
                </p>
                <p className="text-sm text-muted-foreground mt-1">
                  or click to browse (PDF, Excel, CSV)
                </p>
              </div>
            </div>

            {files.length > 0 && (
              <div className="space-y-2">
                <h3 className="font-medium">Uploaded Files</h3>
                {files.map((file, index) => (
                  <div key={index} className="flex items-center gap-3 p-3 rounded-lg border">
                    
  {file.filename?.endsWith('.pdf') ? (
                      <FileText className="h-5 w-5 text-red-500" />
                    ) : (
                      <FileSpreadsheet className="h-5 w-5 text-green-500" />
                    )}
                    <span className="flex-1 truncate">{file.filename}</span>
                    <CheckCircle className="h-5 w-5 text-green-500" />
                  </div>
                ))}
              </div>
            )}

            <div className="flex justify-between pt-4">
              <Button variant="outline" onClick={() => setCurrentStep(0)}>
                <ArrowLeft className="mr-2 h-4 w-4" />
                Back
              </Button>
              <Button onClick={() => setCurrentStep(2)} data-testid="continue-to-analyze">
                Continue to Analysis
                <ArrowRight className="ml-2 h-4 w-4" />
              </Button>
            </div>
          </CardContent>
        </Card>
      )}

      {currentStep === 2 && (
        <Card>
          <CardHeader>
            <CardTitle className="flex items-center gap-2">
              <Sparkles className="h-5 w-5 text-primary" />
              AI Document Analysis
            </CardTitle>
            <CardDescription>
              Let AI analyze your uploaded documents to extract job setup information
            </CardDescription>
          </CardHeader>
          <CardContent className="space-y-6">
            <div className="bg-muted/50 rounded-lg p-6 text-center">
              <Sparkles className="h-12 w-12 text-primary mx-auto mb-4" />
              <h3 className="text-lg font-medium mb-2">Ready to Analyze</h3>
              <p className="text-muted-foreground max-w-md mx-auto">
                AI will extract scope items, programme dates, task codes, materials, 
                and more from your uploaded documents.
              </p>
              {files.length === 0 && (
                <div className="mt-4 p-3 bg-amber-500/10 rounded-lg text-amber-700">
                  <AlertCircle className="h-4 w-4 inline mr-2" />
                  No files uploaded. Analysis will be limited.
                </div>
              )}
            </div>

            <div className="flex justify-between pt-4">
              <Button variant="outline" onClick={() => setCurrentStep(1)}>
                <ArrowLeft className="mr-2 h-4 w-4" />
                Back
              </Button>
              <Button onClick={handleAnalyze} disabled={analyzing} data-testid="run-analysis-btn">{analyzing ? (<>`r`n                    <Loader2 className="mr-2 h-4 w-4 animate-spin" />`r`n                    Analyzing...`r`n                  </>) : (<>`r`n                    <Sparkles className="mr-2 h-4 w-4" />`r`n                    Run AI Analysis`r`n                  </>)}</Button>
            </div>
          </CardContent>
        </Card>
      )}

      {currentStep === 3 && analysis && (
        <div className="space-y-6">
          <Card>
            <CardHeader>
              <CardTitle>Review AI Analysis</CardTitle>
              <CardDescription>
                Review and confirm the extracted information before saving
              </CardDescription>
            </CardHeader>
          </Card>

          <Tabs defaultValue="summary" className="space-y-4">
            <TabsList className="grid w-full grid-cols-5">
              <TabsTrigger value="summary">Summary</TabsTrigger>
              <TabsTrigger value="scope">Scope Items</TabsTrigger>
              <TabsTrigger value="tasks">Tasks</TabsTrigger>
              <TabsTrigger value="codes">Task Codes</TabsTrigger>
              <TabsTrigger value="programme">Programme</TabsTrigger>
            </TabsList>

            <TabsContent value="summary">
              <Card>
                <CardContent className="pt-6">
                  {analysis.job_summary ? (
                    typeof analysis.job_summary === "string" ? (
                      <div className="space-y-3">
                        <p className="whitespace-pre-wrap">{analysis.job_summary}</p>
                      </div>
                    ) : (
                      <div className="space-y-4"><p className="whitespace-pre-wrap">{analysis.job_summary}</p>
                        {analysis.job_summary.description && (
                          <p className="whitespace-pre-wrap">{analysis.job_summary.description}</p>
                        )}

                        {(analysis.job_summary.location || analysis.job_summary.job_code) && (
                          <div className="space-y-1">
                            {analysis.job_summary.location && (
                              <p><span className="font-medium">Location:</span> {analysis.job_summary.location}</p>
                            )}
                            {analysis.job_summary.job_code && (
                              <p><span className="font-medium">Job Code:</span> {analysis.job_summary.job_code}</p>
                            )}
                          </div>
                        )}

                        {analysis.job_summary.general_notes?.length > 0 && (
                          <div>
                            <p className="font-medium mb-2">General Notes:</p>
                            <ul className="list-disc pl-5 space-y-1">
                              {analysis.job_summary.general_notes.map((m, i) => (
                                <li key={i}>{m}</li>
                              ))}
                            </ul>
                          </div>
                        )}
                      </div>
                    )
                  ) : (
                    <p className="text-muted-foreground">No summary extracted</p>
                  )}
                </CardContent>
              </Card>
            </TabsContent>

            <TabsContent value="scope">
              <Card>
                <CardContent className="pt-6">
                  <ScrollArea className="h-[400px]">
                    {analysis.scope_items?.length > 0 ? (
                      <div className="space-y-2">
                        {analysis.scope_items.map((item, index) => (
                          <div key={index} className="flex items-start gap-3 p-3 rounded-lg border">
                            <Checkbox
                              checked={confirmedData.scope_items.includes(item)}
                              onCheckedChange={(checked) => toggleItem('scope_items', item, checked)}
                            />
                            <div className="flex-1 min-w-0">
    </button>

                                <span className="font-medium">{typeof item === "string" ? item : item.item}</span>
                                {typeof item === "object" && item.confidence ? <ConfidenceBadge level={item.confidence} /> : null}
                              </div>
                              {item.quantity && (
                                <p className="text-sm text-muted-foreground">
                                  {item.quantity} {item.unit}
                                  {item.quoted_hours && ` â€˘ ${item.quoted_hours}h quoted`}
                                </p>
                              )}
                            </div>
                          </div>
                        ))}
                      </div>
                    ) : (
                      <p className="text-muted-foreground text-center py-8">
                        No scope items extracted
                      </p>
                    )}
                  </ScrollArea>
                </CardContent>
              </Card>
            </TabsContent>

            <TabsContent value="tasks">
              <Card>
                <CardContent className="pt-6">
                  <ScrollArea className="h-[400px]">
                    {analysis.proposed_tasks?.length > 0 ? (
                      <div className="space-y-2">
                        {analysis.proposed_tasks.map((task, index) => (
                          <div key={index} className="flex items-start gap-3 p-3 rounded-lg border">
                            <Checkbox
                              checked={confirmedData.tasks.includes(task)}
                              onCheckedChange={(checked) => toggleItem('tasks', task, checked)}
                            />
                            <div className="flex-1 min-w-0">
                              <div className="flex items-center gap-2">
                                <span className="font-medium">{typeof task === "string" ? task : (task.name || task.task || "Unnamed task")}</span>
                                {typeof task === "object" && task.confidence ? <ConfidenceBadge level={task.confidence} /> : null}
                              </div>
                              <p className="text-sm text-muted-foreground">
                                {typeof task === "object" && task.type && `${task.type} • `}
                                {typeof task === "object" && task.duration_days && `${task.duration_days} days`}
                              </p>
                              {typeof task === "object" && task.suggested_codes?.length > 0 && (
                                <div className="flex gap-1 mt-1">
                                  {task.suggested_codes.map((code, i) => (
                                    <Badge key={i} variant="outline" className="text-xs">
                                      {code}
                                    </Badge>
                                  ))}
                                </div>
                              )}
                            </div>
                          </div>
                        ))}
                      </div>
                    ) : (
                      <p className="text-muted-foreground text-center py-8">
                        No tasks extracted
                      </p>
                    )}
                  </ScrollArea>
                </CardContent>
              </Card>
            </TabsContent>

            <TabsContent value="codes">
              <Card>
                <CardContent className="pt-6">
                  <ScrollArea className="h-[400px]">
                    {analysis.proposed_task_codes?.length > 0 ? (
                      <div className="space-y-2">
                        {analysis.proposed_task_codes.map((code, index) => (
                          <div key={index} className="flex items-start gap-3 p-3 rounded-lg border">
                            <Checkbox
                              checked={confirmedData.task_codes.includes(code)}
                              onCheckedChange={(checked) => toggleItem('task_codes', code, checked)}
                            />
                            <div className="flex-1 min-w-0">
                              <span className="font-mono font-bold">{typeof code === "string" ? code : code.code}</span>
                              {code.reason && (
                                <p className="text-sm text-muted-foreground mt-1">{code.reason}</p>
                              )}
                            </div>
                          </div>
                        ))}
                      </div>
                    ) : (
                      <p className="text-muted-foreground text-center py-8">
                        No task codes suggested
                      </p>
                    )}
                  </ScrollArea>
                </CardContent>
              </Card>
            </TabsContent>
            <TabsContent value="programme">
  <Card>
    <CardContent className="pt-6">
      <div className="flex justify-end mb-3">
        <Button type="button" variant="outline" size="sm" onClick={addProgrammeItem}>
          <Plus className="mr-2 h-4 w-4" />
          Add Programme Item
        </Button>
      </div>

      <ScrollArea className="h-[400px]">
        {(programmeItems?.length > 0 ? programmeItems : (analysis?.proposed_programme || [])).length > 0 ? (
          <div className="space-y-3">
            {(programmeItems?.length > 0 ? programmeItems : (analysis?.proposed_programme || [])).map((item, index) => (
              <div key={index} className="p-3 rounded-lg border space-y-3">
                <div className="flex items-center justify-between gap-3">
                  <div className="font-medium">{index + 1}.</div>
                  <div className="flex items-center gap-2">
                    {item.confidence && item.confidence !== "manual" ? (
                      <ConfidenceBadge level={item.confidence} />
                    ) : null}
                    <Button
                      type="button"
                      variant="ghost"
                      size="sm"
                      onClick={() => removeProgrammeItem(index)}
                    >
                      <Trash2 className="h-4 w-4" />
                    </Button>
                  </div>
                </div>

                <Input
                  value={item.name || ""}
                  onChange={(e) => updateProgrammeField(index, "name", e.target.value)}
                  placeholder="Programme task name"
                />

                <div className="grid grid-cols-1 md:grid-cols-3 gap-2">
                  <Input
                    value={item.phase || ""}
                    onChange={(e) => updateProgrammeField(index, "phase", e.target.value)}
                    placeholder="Phase"
                  />
                  <Input
                    value={item.trade || ""}
                    onChange={(e) => updateProgrammeField(index, "trade", e.target.value)}
                    placeholder="Trade"
                  />
                  <div className="flex gap-2">
                    <Input
                      type="number"
                      step="0.5"
                      value={item.duration ?? ""}
                      onChange={(e) => updateProgrammeField(index, "duration", e.target.value)}
                      placeholder="Duration"
                    />
                    <Input
                      value={item.duration_unit || "days"}
                      onChange={(e) => updateProgrammeField(index, "duration_unit", e.target.value)}
                      placeholder="Unit"
                    />
                  </div>
                </div>

                <Input
                  value={Array.isArray(item.depends_on) ? item.depends_on.join(", ") : ""}
                  onChange={(e) => updateProgrammeField(index, "depends_on", e.target.value.split(",").map(x => x.trim()).filter(Boolean))}
                  placeholder="Depends on (comma separated ids)"
                />
              </div>
            ))}
          </div>
        ) : (
          <p className="text-muted-foreground text-center py-8">
            No programme generated
          </p>
        )}
      </ScrollArea>
    </CardContent>
  </Card>
</TabsContent>
          </Tabs>

          <div className="flex justify-between">
            <Button variant="outline" onClick={() => setCurrentStep(2)}>
              <ArrowLeft className="mr-2 h-4 w-4" />
              Re-analyze
            </Button>
            <Button onClick={handleConfirm} disabled={loading} data-testid="confirm-setup-btn">
              {loading && <Loader2 className="mr-2 h-4 w-4 animate-spin" />}
              <Check className="mr-2 h-4 w-4" />
              Confirm & Save
            </Button>
          </div>
        </div>
      )}
    </div>
  );
}


































