import { useEffect, useState } from "react";
import api from "@/lib/api";

export default function GanttPage() {
  const [tasks, setTasks] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    async function load() {
      try {
        const res = await api.get("/tasks");
        setTasks(res.data || []);
      } catch (e) {
        console.error(e);
      } finally {
        setLoading(false);
      }
    }

    load();
  }, []);

  if (loading) return <div className="p-6">Loading Gantt...</div>;

  if (!tasks.length) return <div className="p-6">No tasks</div>;

  const maxFinish = Math.max(...tasks.map(t => t.early_finish || 0));

  return (
    <div className="p-6 space-y-4">
      <div className="text-xl font-semibold">Gantt (CPM)</div>

      <div className="space-y-2">
        {tasks.map((t) => {
          const start = t.early_start || 0;
          const finish = t.early_finish || 0;
          const duration = finish - start;

          const left = (start / maxFinish) * 100;
          const width = (duration / maxFinish) * 100;

          return (
            <div key={t.id} className="flex items-center gap-3">
              
              <div className="w-64 text-sm truncate">
                {t.task_name}
              </div>

              <div className="flex-1 relative h-6 bg-slate-200 rounded">

                <div
                  className={`absolute h-6 rounded ${
                    t.is_critical ? "bg-red-500" : "bg-blue-500"
                  }`}
                  style={{
                    left: `${left}%`,
                    width: `${width}%`
                  }}
                />

              </div>

            </div>
          );
        })}
      </div>
    </div>
  );
}
