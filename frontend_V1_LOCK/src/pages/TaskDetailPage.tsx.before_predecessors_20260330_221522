import { useEffect, useState } from "react";
import { useParams, useNavigate } from "react-router-dom";
import api from "@/lib/api";

export default function TaskDetailPage() {
  const { task_id } = useParams();
  const navigate = useNavigate();

  const [task, setTask] = useState<any>(null);
  const [isLoading, setIsLoading] = useState(true);
  const [hasError, setHasError] = useState(false);

  useEffect(() => {
    let mounted = true;

    async function loadTask() {
      try {
        setIsLoading(true);
        setHasError(false);

        const response = await api.get(`/tasks/${task_id}`);

        if (mounted) {
          setTask(response.data);
        }
      } catch (err) {
        if (mounted) {
          setHasError(true);
        }
      } finally {
        if (mounted) {
          setIsLoading(false);
        }
      }
    }

    if (task_id) {
      loadTask();
    }

    return () => {
      mounted = false;
    };
  }, [task_id]);

  if (isLoading) {
    return (
      <div className="p-8 max-w-5xl mx-auto text-muted-foreground">
        Loading task...
      </div>
    );
  }

  if (hasError || !task) {
    return (
      <div className="p-8 max-w-5xl mx-auto text-red-500">
        Failed to load task
      </div>
    );
  }

  return (
    <div className="p-8 max-w-5xl mx-auto space-y-6">

      {/* BACK BUTTON */}
      <button
        onClick={() => navigate(-1)}
        className="text-sm text-muted-foreground hover:text-foreground transition"
      >
        ? Back to Dashboard
      </button>

      {/* HEADER */}
      <div className="space-y-1">
        <h1 className="text-2xl font-semibold tracking-tight">
          {task.task_name}
        </h1>
        <div className="text-sm text-muted-foreground">
          Task ID: {task_id}
        </div>
      </div>

      {/* METRICS */}
      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div>
          <div className="text-sm text-muted-foreground">Duration (Days)</div>
          <div className="text-lg font-medium">{task.duration_days ?? "-"}</div>
        </div>

        <div>
          <div className="text-sm text-muted-foreground">Total Float</div>
          <div className="text-lg font-medium">{task.total_float ?? "-"}</div>
        </div>

        <div>
          <div className="text-sm text-muted-foreground">Early Start</div>
          <div className="text-lg font-medium">{task.early_start ?? "-"}</div>
        </div>

        <div>
          <div className="text-sm text-muted-foreground">Early Finish</div>
          <div className="text-lg font-medium">{task.early_finish ?? "-"}</div>
        </div>

        <div>
          <div className="text-sm text-muted-foreground">Crew Required</div>
          <div className="text-lg font-medium">{task.crew_required ?? "-"}</div>
        </div>

        <div>
          <div className="text-sm text-muted-foreground">Quoted Hours</div>
          <div className="text-lg font-medium">{task.quoted_hours ?? "-"}</div>
        </div>

      </div>

    </div>
  );
}
