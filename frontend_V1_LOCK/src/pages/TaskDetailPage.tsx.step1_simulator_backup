import { useEffect, useState } from "react";
import { useParams, useNavigate } from "react-router-dom";
import api from "@/lib/api";

export default function TaskDetailPage() {
  const { task_id } = useParams();
  const navigate = useNavigate();

  const [task, setTask] = useState<any>(null);
  const [isLoading, setIsLoading] = useState(true);
  const [hasError, setHasError] = useState(false);
  const [criticalOnly, setCriticalOnly] = useState(false);

  useEffect(() => {
    let mounted = true;

    async function loadTask() {
      try {
        setIsLoading(true);
        setHasError(false);

        const response = await api.get(`/tasks/${task_id}`);

        if (mounted) {
          setTask(response.data);
        }
      } catch (err) {
        if (mounted) {
          setHasError(true);
        }
      } finally {
        if (mounted) {
          setIsLoading(false);
        }
      }
    }

    if (task_id) {
      loadTask();
    }

    return () => {
      mounted = false;
    };
  }, [task_id]);

  if (isLoading) {
    return (
      <div className="p-8 max-w-5xl mx-auto text-muted-foreground">
        Loading task...
      </div>
    );
  }

  if (hasError || !task) {
    return (
      <div className="p-8 max-w-5xl mx-auto text-red-500">
        Failed to load task
      </div>
    );
  }

  const downstreamChain = (task.downstream_chain || []) as any[];
  const filteredDownstreamChain = downstreamChain.filter(
    (c: any) => !criticalOnly || c.is_critical
  );

  return (
    <div className="p-8 max-w-5xl mx-auto space-y-8">
      <button
        onClick={() => navigate(-1)}
        className="text-sm text-muted-foreground hover:text-foreground transition"
      >
← Back to Dashboard
      </button>

      <div className="space-y-3">
        <div className="flex items-center gap-3">
          <h1 className="text-2xl font-semibold tracking-tight">
            {task.task_name}
          </h1>
          {task.is_critical && (
            <span className="text-xs font-medium px-2 py-1 rounded bg-red-100 text-red-700 border border-red-200">
              CRITICAL
            </span>
          )}
        </div>

        <div className="text-sm text-muted-foreground">
          Task ID: {task_id}
        </div>

        <div className="grid grid-cols-1 md:grid-cols-3 gap-4 p-4 border rounded-lg bg-muted/20">
          <div>
            <div className="text-xs text-muted-foreground">Driven By</div>
            <div className="text-sm font-medium">
              {task.upstream_chain?.[0]?.task_name ?? "Start Task"}
            </div>
          </div>

          <div>
            <div className="text-xs text-muted-foreground">Drives</div>
            <div className="text-sm font-medium">
              {task.downstream_chain?.[0]?.task_name ?? "End Task"}
            </div>
          </div>

          <div>
            <div className="text-xs text-muted-foreground">Result</div>
            <div
              className={`text-sm font-medium ${
                task.is_critical ? "text-red-600" : "text-muted-foreground"
              }`}
            >
              {task.is_critical ? "Critical Path" : "Non-Critical"}
            </div>
          </div>
        </div>
      </div>

      {task.delay_impact && (
        <div className="grid grid-cols-2 md:grid-cols-4 gap-4 p-4 border rounded-lg bg-red-50/40">
          <div>
            <div className="text-xs text-muted-foreground">Impacted Tasks</div>
            <div className="text-lg font-semibold">{task.delay_impact.total_impacted_tasks}</div>
          </div>

          <div>
            <div className="text-xs text-muted-foreground">Critical Impact</div>
            <div className="text-lg font-semibold text-red-600">{task.delay_impact.critical_impacted_tasks}</div>
          </div>

          <div>
            <div className="text-xs text-muted-foreground">Non-Critical</div>
            <div className="text-lg font-semibold">{task.delay_impact.non_critical_impacted_tasks}</div>
          </div>

          <div>
            <div className="text-xs text-muted-foreground">Delay Risk</div>
            <div className="text-lg font-semibold text-red-600">+{task.delay_impact.max_delay_risk_days} days</div>
          </div>
        </div>
      )}


      <div className="grid grid-cols-2 md:grid-cols-3 gap-6">
        <div>
          <div className="text-sm text-muted-foreground">Duration</div>
          <div className="text-lg font-medium">{task.duration_days ?? "-"}</div>
        </div>

        <div>
          <div className="text-sm text-muted-foreground">Float</div>
          <div className="text-lg font-medium">{task.total_float ?? "-"}</div>
        </div>

        <div>
          <div className="text-sm text-muted-foreground">Early Start</div>
          <div className="text-lg font-medium">{task.early_start ?? "-"}</div>
        </div>

        <div>
          <div className="text-sm text-muted-foreground">Early Finish</div>
          <div className="text-lg font-medium">{task.early_finish ?? "-"}</div>
        </div>

        <div>
          <div className="text-sm text-muted-foreground">Crew</div>
          <div className="text-lg font-medium">{task.crew_required ?? "-"}</div>
        </div>

        <div>
          <div className="text-sm text-muted-foreground">Hours</div>
          <div className="text-lg font-medium">{task.quoted_hours ?? "-"}</div>
        </div>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div className="space-y-3">
          <div className="text-sm font-medium text-muted-foreground">
🔗 Immediate Driver
          </div>

          {task.predecessors && task.predecessors.length > 0 ? (
            <div className="space-y-2">
              {task.predecessors.map((p: any) => (
                <button
                  key={p.task_id}
                  onClick={() => navigate(`/tasks/${p.task_id}`)}
                  className={`w-full text-left border rounded-md p-3 transition ${
                    p.is_critical
                      ? "border-red-200 bg-red-50/60 hover:bg-red-50"
                      : "hover:bg-muted/30"
                  }`}
                >
                  <div className="flex items-center gap-2">
                    <div className="font-medium">{p.task_name}</div>
                    {p.is_critical && (
                      <span className="text-[10px] font-medium px-2 py-0.5 rounded bg-red-100 text-red-700 border border-red-200">
                        CRITICAL
                      </span>
                    )}
                  </div>
                </button>
              ))}
            </div>
          ) : (
            <div className="text-sm text-muted-foreground">Start Task</div>
          )}
        </div>

        <div className="space-y-3">
          <div className="text-sm font-medium text-muted-foreground">
➡️ Immediate Impact
          </div>

          {task.successors && task.successors.length > 0 ? (
            <div className="space-y-2">
              {task.successors.map((s: any) => (
                <button
                  key={s.task_id}
                  onClick={() => navigate(`/tasks/${s.task_id}`)}
                  className={`w-full text-left border rounded-md p-3 transition ${
                    s.is_critical
                      ? "border-red-200 bg-red-50/60 hover:bg-red-50"
                      : "hover:bg-muted/30"
                  }`}
                >
                  <div className="flex items-center gap-2">
                    <div className="font-medium">{s.task_name}</div>
                    {s.is_critical && (
                      <span className="text-[10px] font-medium px-2 py-0.5 rounded bg-red-100 text-red-700 border border-red-200">
                        CRITICAL
                      </span>
                    )}
                  </div>
                </button>
              ))}
            </div>
          ) : (
            <div className="text-sm text-muted-foreground">End Task</div>
          )}
        </div>
      </div>

      <div className="space-y-3">
        <div className="flex items-center justify-between">
          <div className="text-sm font-medium text-muted-foreground">
🔥 Downstream Impact Chain
          </div>
          <button
            onClick={() => setCriticalOnly(!criticalOnly)}
            className="text-xs px-3 py-1 border rounded hover:bg-muted/30 transition"
          >
            {criticalOnly ? "Show All" : "Critical Only"}
          </button>
        </div>

        {filteredDownstreamChain.length > 0 ? (
          <div className="space-y-2">
            {filteredDownstreamChain.map((c: any, idx: number) => (
              <button
                key={`${c.task_id}-${idx}`}
                onClick={() => navigate(`/tasks/${c.task_id}`)}
                className={`w-full text-left border rounded-md p-3 transition ${
                  c.is_critical
                    ? "border-red-300 bg-red-50 shadow-sm hover:bg-red-50"
                    : "hover:bg-muted/30"
                }`}
              >
                <div className="flex items-center gap-2">
                  <div className="font-medium">{c.task_name}</div>
                  {c.is_critical && (
                    <span className="text-[10px] font-medium px-2 py-0.5 rounded bg-red-100 text-red-700 border border-red-200">
                      CRITICAL
                    </span>
                  )}
                </div>
                <div className="text-xs text-muted-foreground">
                  Chain step {idx + 1}
                </div>
              </button>
            ))}
          </div>
        ) : (
          <div className="text-sm text-muted-foreground">
            No downstream chain
          </div>
        )}
      </div>
    </div>
  );
}




