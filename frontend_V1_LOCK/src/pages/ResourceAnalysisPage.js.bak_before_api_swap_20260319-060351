import React, { useEffect, useState } from "react";
import { Link, useNavigate, useParams } from "react-router-dom";
import api from "@/lib/api";
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { Loader2, ArrowLeft } from "lucide-react";
import {
  ResponsiveContainer,
  BarChart,
  Bar,
  XAxis,
  YAxis,
  Tooltip,
  CartesianGrid,
  ReferenceLine,
} from "recharts";
import { toast } from "sonner";

const formatHours = (value) => {
  if (value === null || value === undefined || value === "") return "-";
  const num = Number(value);
  if (Number.isNaN(num)) return "-";
  return `${num.toFixed(2)}h`;
};

const formatNumber = (value, digits = 1) => {
  if (value === null || value === undefined || value === "") return "-";
  const num = Number(value);
  if (Number.isNaN(num)) return "-";
  return num.toFixed(digits);
};

const formatPercent = (value) => {
  if (value === null || value === undefined || value === "") return "-";
  const num = Number(value);
  if (Number.isNaN(num)) return "-";
  return `${num.toFixed(1)}%`;
};

const formatShortDate = (value) => {
  if (!value) return "-";
  const d = new Date(value);
  if (Number.isNaN(d.getTime())) return "-";
  return d.toLocaleDateString("en-NZ", { day: "2-digit", month: "short" });
};

const statusClass = (status) => {
  switch (status) {
    case "ON_TRACK":
      return "bg-green-100 text-green-800 border border-green-200";
    case "SATURDAY_REQUIRED":
      return "bg-amber-100 text-amber-800 border border-amber-200";
    case "OVERALLOCATED":
      return "bg-red-100 text-red-800 border border-red-200";
    case "NO_QUOTED_HOURS":
      return "bg-slate-100 text-slate-800 border border-slate-200";
    default:
      return "bg-slate-100 text-slate-700 border border-slate-200";
  }
};

export default function ResourceAnalysisPage() {
  const { jobId } = useParams();
  const navigate = useNavigate();
  const [loading, setLoading] = useState(true);
  const [analysis, setAnalysis] = useState(null);
  const [errorState, setErrorState] = useState(null);
  const [sortBy, setSortBy] = useState("crew");
  const [statusFilter, setStatusFilter] = useState("all");

  useEffect(() => {
    const loadAnalysis = async () => {
      if (!jobId) {
        setErrorState("missing-job-id");
        setAnalysis(null);
        setLoading(false);
        return;
      }

      setLoading(true);
      setErrorState(null);

      try {
        const res = await api.get(`/jobs/${jobId}/resource-analysis`);
        setAnalysis(res.data || null);
      } catch (error) {
        console.error(error);

        if (error.response?.status === 404) {
          setErrorState("not-found");
        } else if (error.response?.status === 400) {
          setErrorState("invalid-job");
        } else {
          setErrorState("load-failed");
          toast.error("Failed to load resource analysis");
        }

        setAnalysis(null);
      } finally {
        setLoading(false);
      }
    };

    loadAnalysis();
  }, [jobId]);

  if (loading) {
    return (
      <div className="flex items-center justify-center min-h-[400px]">
        <Loader2 className="h-8 w-8 animate-spin text-primary" />
      </div>
    );
  }

  if (errorState === "missing-job-id" || errorState === "invalid-job") {
    return (
      <div className="space-y-6" data-testid="resource-analysis-page">
        <div className="flex items-center justify-between gap-3">
          <div>
            <h1 className="text-3xl font-bold font-['Manrope']">Resource Analysis</h1>
            <p className="text-muted-foreground mt-1">A valid job is required.</p>
          </div>
          <Button variant="outline" onClick={() => navigate("/jobs")}>
            <ArrowLeft className="mr-2 h-4 w-4" />
            Back to Jobs
          </Button>
        </div>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">Invalid Job</CardTitle>
            <CardDescription>The job link is missing or invalid.</CardDescription>
          </CardHeader>
        </Card>
      </div>
    );
  }

  if (errorState === "not-found") {
    return (
      <div className="space-y-6" data-testid="resource-analysis-page">
        <div className="flex items-center justify-between gap-3">
          <div>
            <h1 className="text-3xl font-bold font-['Manrope']">Resource Analysis</h1>
            <p className="text-muted-foreground mt-1">Job not found.</p>
          </div>
          <Button variant="outline" onClick={() => navigate("/jobs")}>
            <ArrowLeft className="mr-2 h-4 w-4" />
            Back to Jobs
          </Button>
        </div>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">Job Not Found</CardTitle>
            <CardDescription>The selected job does not exist or has been removed.</CardDescription>
          </CardHeader>
        </Card>
      </div>
    );
  }

  if (errorState === "load-failed" || !analysis) {
    return (
      <div className="space-y-6" data-testid="resource-analysis-page">
        <div className="flex items-center justify-between gap-3">
          <div>
            <h1 className="text-3xl font-bold font-['Manrope']">Resource Analysis</h1>
            <p className="text-muted-foreground mt-1">Labour intelligence by task</p>
          </div>
          <div className="flex gap-2">
            <Link to="/jobs">
              <Button variant="outline">
                <ArrowLeft className="mr-2 h-4 w-4" />
                Back to Jobs
              </Button>
            </Link>
            <Button onClick={() => window.location.reload()}>
              Retry
            </Button>
          </div>
        </div>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">No Data</CardTitle>
            <CardDescription>No resource analysis data available for this job.</CardDescription>
          </CardHeader>
        </Card>
      </div>
    );
  }

  const summary = analysis.summary || {};
  const hasNoTaskData = (summary.total_tasks ?? 0) === 0 && (analysis.tasks?.length ?? 0) === 0;

  const filteredAndSortedTasks = (analysis.tasks || [])
    .filter((task) => {
      if (statusFilter === "all") return true;
      return (task.programme_feasible || "").toUpperCase() === statusFilter;
    })
    .slice()
    .sort((a, b) => {
      switch (sortBy) {
        case "task":
          return (a.task_name || "").localeCompare(b.task_name || "");
        case "quoted":
          return (Number(b.quoted_hours) || 0) - (Number(a.quoted_hours) || 0);
        case "variance":
          return (Number(b.hours_variance) || 0) - (Number(a.hours_variance) || 0);
        case "used":
          return (Number(b.percent_hours_used) || 0) - (Number(a.percent_hours_used) || 0);
        case "crew":
        default:
          return (Number(b.required_crew_standard) || 0) - (Number(a.required_crew_standard) || 0);
      }
    });

  const timelineData = filteredAndSortedTasks.map((task) => ({
    name: task.task_name || "Untitled",
    shortName: (task.task_name || "Untitled").length > 24
      ? `${task.task_name.slice(0, 24)}…`
      : (task.task_name || "Untitled"),
    quoted: Number(task.quoted_hours || 0),
    available: Number(task.available_hours_standard || 0),
    crew: Number(task.required_crew_standard || 0),
    percentUsed: Number(task.percent_hours_used || 0),
    status: task.programme_feasible || "-",
    start: task.planned_start || null,
    finish: task.planned_finish || null,
  }));

  const chartData = timelineData.slice(0, 12);
  const crewCapacityLine = 1;

  const chartTooltipFormatter = (value, name) => {
    if (name === "quoted") return [`${Number(value).toFixed(2)}h`, "Quoted"];
    if (name === "available") return [`${Number(value).toFixed(2)}h`, "Available"];
    return [value, name];
  };

  if (hasNoTaskData) {
    return (
      <div className="space-y-6" data-testid="resource-analysis-page">
        <div className="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
          <div>
            <h1 className="text-3xl font-bold font-['Manrope']">Resource Analysis</h1>
            <p className="text-muted-foreground mt-1">
              {analysis.job_number} - {analysis.job_name}
            </p>
          </div>
          <div className="flex gap-2">
            <Link to="/jobs">
              <Button variant="outline">
                <ArrowLeft className="mr-2 h-4 w-4" />
                Back to Jobs
              </Button>
            </Link>
            <Link to={`/jobs/${jobId}`}>
              <Button variant="outline">
                Open Job
              </Button>
            </Link>
            <Link to={`/jobs/${jobId}/setup`}>
              <Button>
                Upload & Analyze
              </Button>
            </Link>
          </div>
        </div>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">No labour basis yet</CardTitle>
            <CardDescription>
              This job has no generated tasks or approved quoted hours yet, so resource analysis cannot calculate labour demand.
            </CardDescription>
          </CardHeader>
          <CardContent className="space-y-3 text-sm text-muted-foreground">
            <p>Complete one of these first:</p>
            <ul className="list-disc pl-5 space-y-1">
              <li>upload and analyze programme / scope files</li>
              <li>generate tasks from the programme</li>
              <li>add tasks manually with quoted hours</li>
              <li>approve scope hours so baseline labour exists</li>
            </ul>
          </CardContent>
        </Card>
      </div>
    );
  }

  return (
    <div className="space-y-6" data-testid="resource-analysis-page">
      <div className="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
        <div>
          <h1 className="text-3xl font-bold font-['Manrope']">Resource Analysis</h1>
          <p className="text-muted-foreground mt-1">
            {analysis.job_number} - {analysis.job_name}
          </p>
        </div>
        <div className="flex items-center gap-2">
          <Link to="/jobs">
            <Button variant="outline">
              <ArrowLeft className="mr-2 h-4 w-4" />
              Back to Jobs
            </Button>
          </Link>
          <div className={`inline-flex w-fit items-center rounded-md px-3 py-1.5 text-sm font-semibold ${statusClass(summary.overall_status)}`}>
            {summary.overall_status || "-"}
          </div>
        </div>
      </div>

      <div className="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
        <Card>
          <CardContent className="pt-6">
            <p className="text-sm text-muted-foreground">Total Tasks</p>
            <p className="text-2xl font-bold">{summary.total_tasks ?? "-"}</p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="pt-6">
            <p className="text-sm text-muted-foreground">Total Quoted</p>
            <p className="text-2xl font-bold">{formatHours(summary.total_quoted_hours)}</p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="pt-6">
            <p className="text-sm text-muted-foreground">Total Actual</p>
            <p className="text-2xl font-bold">{formatHours(summary.total_actual_hours)}</p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="pt-6">
            <p className="text-sm text-muted-foreground">Variance</p>
            <p className="text-2xl font-bold">{formatHours(summary.total_hours_variance)}</p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="pt-6">
            <p className="text-sm text-muted-foreground">Hours Used</p>
            <p className="text-2xl font-bold">{formatPercent(summary.percent_hours_used)}</p>
          </CardContent>
        </Card>
      </div>

      <div className="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        <Card>
          <CardHeader>
            <CardTitle className="text-lg">Programme Capacity</CardTitle>
            <CardDescription>Available labour window from programme dates</CardDescription>
          </CardHeader>
          <CardContent className="space-y-2">
            <div className="flex items-center justify-between gap-4">
              <span className="text-sm text-muted-foreground">Standard Hours</span>
              <span className="font-semibold">{formatHours(summary.total_available_hours_standard)}</span>
            </div>
            <div className="flex items-center justify-between gap-4">
              <span className="text-sm text-muted-foreground">With Saturday</span>
              <span className="font-semibold">{formatHours(summary.total_available_hours_with_saturday)}</span>
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">Quoted Baseline</CardTitle>
            <CardDescription>Current approved labour baseline for this job</CardDescription>
          </CardHeader>
          <CardContent className="space-y-2">
            <div className="flex items-center justify-between gap-4">
              <span className="text-sm text-muted-foreground">Approved Scope Hours</span>
              <span className="font-semibold">{formatHours(summary.total_approved_scope_hours)}</span>
            </div>
            <div className="flex items-center justify-between gap-4">
              <span className="text-sm text-muted-foreground">Baseline Used</span>
              <span className="font-semibold">{formatHours(summary.baseline_hours_used)}</span>
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">Crew Demand Snapshot</CardTitle>
            <CardDescription>Highest standard crew demand in current filtered set</CardDescription>
          </CardHeader>
          <CardContent className="space-y-2">
            <div className="flex items-center justify-between gap-4">
              <span className="text-sm text-muted-foreground">Peak Crew</span>
              <span className="font-semibold">
                {formatNumber(
                  filteredAndSortedTasks.reduce((max, task) => {
                    const crew = Number(task.required_crew_standard || 0);
                    return crew > max ? crew : max;
                  }, 0),
                  2
                )}
              </span>
            </div>
            <div className="flex items-center justify-between gap-4">
              <span className="text-sm text-muted-foreground">Tasks in View</span>
              <span className="font-semibold">{filteredAndSortedTasks.length}</span>
            </div>
          </CardContent>
        </Card>
      </div>

      <Card>
        <CardHeader>
          <CardTitle className="text-lg">Timeline / Load Graph</CardTitle>
          <CardDescription>
            Quoted hours against available standard-window hours for the current filtered tasks
          </CardDescription>
        </CardHeader>
        <CardContent className="space-y-4">
          <div className="grid gap-3 text-sm text-muted-foreground md:grid-cols-3">
            <div className="rounded-lg border p-3">
              Showing top {chartData.length} tasks from current sort/filter
            </div>
            <div className="rounded-lg border p-3">
              Overload risk = quoted hours above available hours
            </div>
            <div className="rounded-lg border p-3">
              Crew guide line = {crewCapacityLine.toFixed(0)} standard crew
            </div>
          </div>

          <div className="h-[360px] w-full">
            <ResponsiveContainer width="100%" height="100%">
              <BarChart
                data={chartData}
                margin={{ top: 8, right: 16, left: 0, bottom: 60 }}
              >
                <CartesianGrid strokeDasharray="3 3" />
                <XAxis
                  dataKey="shortName"
                  angle={-25}
                  textAnchor="end"
                  interval={0}
                  height={80}
                />
                <YAxis />
                <Tooltip
                  formatter={chartTooltipFormatter}
                  labelFormatter={(label, payload) => {
                    const row = payload?.[0]?.payload;
                    if (!row) return label;
                    return `${row.name} | ${formatShortDate(row.start)} ? ${formatShortDate(row.finish)} | ${row.status}`;
                  }}
                />
                <ReferenceLine y={0} />
                <Bar dataKey="available" name="available" radius={[4, 4, 0, 0]} />
                <Bar dataKey="quoted" name="quoted" radius={[4, 4, 0, 0]} />
              </BarChart>
            </ResponsiveContainer>
          </div>

          <div className="overflow-x-auto">
            <table className="data-table w-full">
              <thead>
                <tr>
                  <th>Task</th>
                  <th>Dates</th>
                  <th className="text-right">Quoted</th>
                  <th className="text-right">Available</th>
                  <th className="text-right">Crew</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                {chartData.map((row) => (
                  <tr key={`${row.name}-${row.start}-${row.finish}`}>
                    <td>{row.name}</td>
                    <td>{formatShortDate(row.start)} - {formatShortDate(row.finish)}</td>
                    <td className="text-right">{formatHours(row.quoted)}</td>
                    <td className="text-right">{formatHours(row.available)}</td>
                    <td className="text-right">{formatNumber(row.crew, 2)}</td>
                    <td>
                      <span className={`inline-flex items-center rounded-md px-2 py-1 text-xs font-semibold ${statusClass(row.status)}`}>
                        {row.status}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </CardContent>
      </Card>

      <Card>
        <CardHeader>
          <CardTitle className="text-lg">Task Breakdown</CardTitle>
          <CardDescription>Quoted, actual, crew demand, and programme status by task</CardDescription>
        </CardHeader>
        <CardContent>
          <div className="mb-4 grid gap-3 md:grid-cols-2">
            <div>
              <p className="text-sm text-muted-foreground mb-2">Sort By</p>
              <Select value={sortBy} onValueChange={setSortBy}>
                <SelectTrigger>
                  <SelectValue />
                </SelectTrigger>
                <SelectContent>
                  <SelectItem value="crew">Crew Demand</SelectItem>
                  <SelectItem value="variance">Variance</SelectItem>
                  <SelectItem value="quoted">Quoted Hours</SelectItem>
                  <SelectItem value="used">% Used</SelectItem>
                  <SelectItem value="task">Task Name</SelectItem>
                </SelectContent>
              </Select>
            </div>

            <div>
              <p className="text-sm text-muted-foreground mb-2">Status Filter</p>
              <Select value={statusFilter} onValueChange={setStatusFilter}>
                <SelectTrigger>
                  <SelectValue />
                </SelectTrigger>
                <SelectContent>
                  <SelectItem value="all">All</SelectItem>
                  <SelectItem value="OVERALLOCATED">Overallocated</SelectItem>
                  <SelectItem value="SATURDAY_REQUIRED">Saturday Required</SelectItem>
                  <SelectItem value="ON_TRACK">On Track</SelectItem>
                  <SelectItem value="NO_QUOTED_HOURS">No Quoted Hours</SelectItem>
                </SelectContent>
              </Select>
            </div>
          </div>

          <div className="overflow-x-auto">
            <table className="data-table w-full">
              <thead>
                <tr>
                  <th>Task Name</th>
                  <th className="text-right">Quoted</th>
                  <th className="text-right">Actual</th>
                  <th className="text-right">Variance</th>
                  <th className="text-right">% Used</th>
                  <th className="text-right">Crew</th>
                  <th>Saturday</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                {filteredAndSortedTasks.map((task) => (
                  <tr key={task.task_id}>
                    <td>{task.task_name}</td>
                    <td className="text-right">{formatHours(task.quoted_hours)}</td>
                    <td className="text-right">{formatHours(task.actual_hours)}</td>
                    <td className="text-right">{formatHours(task.hours_variance)}</td>
                    <td className="text-right">{formatPercent(task.percent_hours_used)}</td>
                    <td className="text-right">{formatNumber(task.required_crew_standard, 2)}</td>
                    <td>{task.requires_saturday ? "Yes" : "No"}</td>
                    <td>
                      <span className={`inline-flex items-center rounded-md px-2 py-1 text-xs font-semibold ${statusClass(task.programme_feasible)}`}>
                        {task.programme_feasible ?? "-"}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </CardContent>
      </Card>
    </div>
  );
}
