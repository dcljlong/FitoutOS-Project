          </div>
        </div>

        <div>
          <div className="text-xs text-muted-foreground">Result</div>
          <div className={`text-sm font-medium ${task.is_critical ? "text-red-600" : "text-muted-foreground"}`}>
            {task.is_critical ? "Critical Path" : "Non-Critical"}
          </div>
        </div>

      </div>Quoted Hours</div>
          <div className="text-lg font-medium">{task.quoted_hours ?? "-"}</div>
        </div>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div className="space-y-3">
          <div className="text-sm font-medium text-muted-foreground">
            ⬅️ Tasks Before (Predecessors)
          </div>

          {task.predecessors && task.predecessors.length > 0 ? (
            <div className="space-y-2">
              {task.predecessors.map((p: any) => (
                <button
                  key={p.task_id}
                  onClick={() => navigate(`/tasks/${p.task_id}`)}
                  className={`w-full text-left border rounded-md p-3 transition ${p.is_critical ? (isCriticalContext ? "border-red-300 bg-red-50 shadow-sm hover:bg-red-50" : "border-red-200 bg-red-50/60 hover:bg-red-50") : "hover:bg-muted/30"}`}
                >
                  <div className="flex items-center gap-2">
                    <div className="font-medium">{p.task_name}</div>
                    {p.is_critical && (
                      <span className="text-[10px] font-medium px-2 py-0.5 rounded bg-red-100 text-red-700 border border-red-200">
                        CRITICAL
                      </span>
                    )}
                  </div>
                  <div className="text-xs text-muted-foreground">
                    Finish → Start dependency
                  </div>
                </button>
              ))}
            </div>
          ) : (
            <div className="text-sm text-muted-foreground">
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4 p-4 border rounded-lg bg-muted/20">
        
        <div>
          <div className="text-xs text-muted-foreground">Driven By</div>
          <div className="text-sm font-medium">
            {task.upstream_chain?.[0]?.task_name ?? "Start Task"}
          </div>
        </div>

        <div>
          <div className="text-xs text-muted-foreground">Drives</div>
          <div className="text-sm font-medium">
            {task.downstream_chain?.[0]?.task_name ?? "End Task"}
          </div>
        </div>

        <div>
          <div className="text-xs text-muted-foreground">Result</div>
          <div className={`text-sm font-medium ${task.is_critical ? "text-red-600" : "text-muted-foreground"}`}>
            {task.is_critical ? "Critical Path" : "Non-Critical"}
          </div>
        </div>

      </div>
              No predecessors (start task)
            </div>
          )}
        </div>

        <div className="space-y-3">
          <div className="text-sm font-medium text-muted-foreground">
            ➡️ Tasks After (Successors)
          </div>

          {task.successors && task.successors.length > 0 ? (
            <div className="space-y-2">
              {task.successors.map((s: any) => (
                <button
                  key={s.task_id}
                  onClick={() => navigate(`/tasks/${s.task_id}`)}
                  className={`w-full text-left border rounded-md p-3 transition ${s.is_critical ? (isCriticalContext ? "border-red-300 bg-red-50 shadow-sm hover:bg-red-50" : "border-red-200 bg-red-50/60 hover:bg-red-50") : "hover:bg-muted/30"}`}
                >
                  <div className="flex items-center gap-2">
                    <div className="font-medium">{s.task_name}</div>
                    {s.is_critical && (
                      <span className="text-[10px] font-medium px-2 py-0.5 rounded bg-red-100 text-red-700 border border-red-200">
                        CRITICAL
                      </span>
                    )}
                  </div>
                  <div className="text-xs text-muted-foreground">
                    This task must finish before successor starts
                  </div>
                </button>
              ))}
            </div>
          ) : (
            <div className="text-sm text-muted-foreground">
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4 p-4 border rounded-lg bg-muted/20">
        
        <div>
          <div className="text-xs text-muted-foreground">Driven By</div>
          <div className="text-sm font-medium">
            {task.upstream_chain?.[0]?.task_name ?? "Start Task"}
          </div>
        </div>

        <div>
          <div className="text-xs text-muted-foreground">Drives</div>
          <div className="text-sm font-medium">
            {task.downstream_chain?.[0]?.task_name ?? "End Task"}
          </div>
        </div>

        <div>
          <div className="text-xs text-muted-foreground">Result</div>
          <div className={`text-sm font-medium ${task.is_critical ? "text-red-600" : "text-muted-foreground"}`}>
            {task.is_critical ? "Critical Path" : "Non-Critical"}
          </div>
        </div>

      </div>
              No successors (end task)
            </div>
          )}
        </div>
      </div>
      <div className="space-y-3">
        <div className="text-sm font-medium text-muted-foreground">
          ⬆️ Full Upstream Chain
        </div>

        {task.upstream_chain && task.upstream_chain.length > 0 ? (
          <div className="space-y-2">
            {task.upstream_chain.map((c: any, idx: number) => (
              <button
                key={`${c.task_id}-${idx}`}
                onClick={() => navigate(`/tasks/${c.task_id}`)}
                className={`w-full text-left border rounded-md p-3 transition ${c.is_critical ? "border-red-300 bg-red-50 shadow-sm hover:bg-red-50" : "hover:bg-muted/30"}`}
              >
                <div className="flex items-center gap-2">
                  <div className="font-medium">{c.task_name}</div>
                  {c.is_critical && (
                    <span className="text-[10px] font-medium px-2 py-0.5 rounded bg-red-100 text-red-700 border border-red-200">
                      CRITICAL
                    </span>
                  )}
                </div>
                <div className="text-xs text-muted-foreground">
                  Chain step {idx + 1}
                </div>
              </button>
            ))}
