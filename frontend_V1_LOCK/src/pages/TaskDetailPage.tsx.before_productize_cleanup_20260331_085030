          <div className="text-sm font-medium">
            {task.downstream_chain?.[0]?.task_name ?? "End Task"}
          </div>
        </div>

        <div>
          <div className="text-xs text-muted-foreground">Result</div>
          <div className={`text-sm font-medium ${task.is_critical ? "text-red-600" : "text-muted-foreground"}`}>
            {task.is_critical ? "Critical Path" : "Non-Critical"}
          </div>
        </div>

      </div>Duration (Days)</div>
          <div className="text-lg font-medium">{task.duration_days ?? "-"}</div>
        </div>

        <div>
          <div className="text-sm text-muted-foreground">
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4 p-4 border rounded-lg bg-muted/20">
        
        <div>
          <div className="text-xs text-muted-foreground">Driven By</div>
          <div className="text-sm font-medium">
            {task.upstream_chain?.[0]?.task_name ?? "Start Task"}
          </div>
        </div>

        <div>
          <div className="text-xs text-muted-foreground">Drives</div>
          <div className="text-sm font-medium">
            {task.downstream_chain?.[0]?.task_name ?? "End Task"}
          </div>
        </div>

        <div>
          <div className="text-xs text-muted-foreground">Result</div>
          <div className={`text-sm font-medium ${task.is_critical ? "text-red-600" : "text-muted-foreground"}`}>
            {task.is_critical ? "Critical Path" : "Non-Critical"}
          </div>
        </div>

      </div>Total Float</div>
          <div className="text-lg font-medium">{task.total_float ?? "-"}</div>
        </div>

        <div>
          <div className="text-sm text-muted-foreground">
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4 p-4 border rounded-lg bg-muted/20">
        
        <div>
          <div className="text-xs text-muted-foreground">Driven By</div>
          <div className="text-sm font-medium">
            {task.upstream_chain?.[0]?.task_name ?? "Start Task"}
          </div>
        </div>

        <div>
          <div className="text-xs text-muted-foreground">Drives</div>
          <div className="text-sm font-medium">
            {task.downstream_chain?.[0]?.task_name ?? "End Task"}
          </div>
        </div>

        <div>
          <div className="text-xs text-muted-foreground">Result</div>
          <div className={`text-sm font-medium ${task.is_critical ? "text-red-600" : "text-muted-foreground"}`}>
            {task.is_critical ? "Critical Path" : "Non-Critical"}
          </div>
        </div>

      </div>Early Start</div>
          <div className="text-lg font-medium">{task.early_start ?? "-"}</div>
        </div>

        <div>
          <div className="text-sm text-muted-foreground">
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4 p-4 border rounded-lg bg-muted/20">
        
        <div>
          <div className="text-xs text-muted-foreground">Driven By</div>
          <div className="text-sm font-medium">
