import { useEffect, useState } from "react";
import { useParams, useNavigate } from "react-router-dom";
import api from "@/lib/api";

export default function TaskDetailPage() {
  const { task_id } = useParams();
  const navigate = useNavigate();

  const [task, setTask] = useState<any>(null);
  const [isLoading, setIsLoading] = useState(true);
  const [hasError, setHasError] = useState(false);
const [criticalOnly, setCriticalOnly] = useState(false);

  useEffect(() => {
    let mounted = true;

    async function loadTask() {
      try {
        setIsLoading(true);
        setHasError(false);

        const response = await api.get(`/tasks/${task_id}`);

        if (mounted) {
          setTask(response.data);
        }
      } catch (err) {
        if (mounted) {
          setHasError(true);
        }
      } finally {
        if (mounted) {
          setIsLoading(false);
        }
      }
    }

    if (task_id) {
      loadTask();
    }

    return () => {
      mounted = false;
    };
  }, [task_id]);

  if (isLoading) {
    return (
      <div className="p-8 max-w-5xl mx-auto text-muted-foreground">
        Loading task...
      </div>
    );
  }

  if (hasError || !task) {
    return (
      <div className="p-8 max-w-5xl mx-auto text-red-500">
        Failed to load task
      </div>
    );
  }
  const isCriticalContext = task?.is_critical === true;

  return (
    <div className="p-8 max-w-5xl mx-auto space-y-8">
      <button
        onClick={() => navigate(-1)}
        className="text-sm text-muted-foreground hover:text-foreground transition"
      >
        ? Back to Dashboard
      </button>

      <div className="space-y-1">
        <div className="flex items-center gap-3">
          <h1 className="text-2xl font-semibold tracking-tight">
            {task.task_name}
          </h1>
          {task.is_critical && (
            <span className="text-xs font-medium px-2 py-1 rounded bg-red-100 text-red-700 border border-red-200">
              CRITICAL
            </span>
          )}
        </div>
        <div className="text-sm text-muted-foreground">
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4 p-4 border rounded-lg bg-muted/20">
        
        <div>
          <div className="text-xs text-muted-foreground">Driven By</div>
          <div className="text-sm font-medium">
            {task.upstream_chain?.[0]?.task_name ?? "Start Task"}
          </div>
        </div>

        <div>
          <div className="text-xs text-muted-foreground">Drives</div>
          <div className="text-sm font-medium">
            {task.downstream_chain?.[0]?.task_name ?? "End Task"}
          </div>
        </div>

        <div>
          <div className="text-xs text-muted-foreground">Result</div>
          <div className={`text-sm font-medium ${task.is_critical ? "text-red-600" : "text-muted-foreground"}`}>
            {task.is_critical ? "Critical Path" : "Non-Critical"}
          </div>
        </div>

      </div>
          Task ID: {task_id}
        </div>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <div className="text-sm text-muted-foreground">
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4 p-4 border rounded-lg bg-muted/20">
        
        <div>
          <div className="text-xs text-muted-foreground">Driven By</div>
          <div className="text-sm font-medium">
