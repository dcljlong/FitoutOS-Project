import { useEffect, useState } from "react";
import { useNavigate } from "react-router-dom";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import api from "@/lib/api";

const JOB_ID = "27ea5733-726f-4d62-a464-22989ca44736";
const TEST_EMAIL = "test@fitout.com";
const TEST_PASSWORD = "123456";

function getFlagClasses(flag: string) {
  switch (flag) {
    case "SEQUENCE ISSUE":
      return {
        card: "border-red-200 bg-red-50/60",
        badge: "bg-red-100 text-red-700 border-red-200",
        action: "text-red-700",
      };
    case "PARALLEL OPPORTUNITY":
      return {
        card: "border-violet-200 bg-violet-50/60",
        badge: "bg-violet-100 text-violet-700 border-violet-200",
        action: "text-violet-700",
      };
    case "STARTING TASK":
      return {
        card: "border-emerald-200 bg-emerald-50/60",
        badge: "bg-emerald-100 text-emerald-700 border-emerald-200",
        action: "text-emerald-700",
      };
    case "DRIVES NEXT TRADE":
      return {
        card: "border-blue-200 bg-blue-50/60",
        badge: "bg-blue-100 text-blue-700 border-blue-200",
        action: "text-blue-700",
      };
    case "FINISH CRITICAL":
      return {
        card: "border-amber-200 bg-amber-50/60",
        badge: "bg-amber-100 text-amber-700 border-amber-200",
        action: "text-amber-700",
      };
    default:
      return {
        card: "border-border/60 bg-white",
        badge: "bg-slate-100 text-slate-600 border-slate-200",
        action: "text-slate-600",
      };
  }
}

function getCodeClasses(code: string) {
  switch (code) {
    case "103":
      return "bg-slate-900 text-white";
    case "105":
      return "bg-blue-600 text-white";
    case "106":
      return "bg-amber-500 text-white";
    case "107":
      return "bg-emerald-600 text-white";
    case "111":
      return "bg-red-600 text-white";
    case "101":
      return "bg-violet-600 text-white";
    default:
      return "bg-slate-200 text-slate-700";
  }
}

function getTradeBucket(code: string) {
  switch (code) {
    case "103":
      return "Framing";
    case "105":
      return "Linings";
    case "106":
      return "Stopping";
    case "107":
      return "Insulation";
    case "111":
      return "Fire Rating";
    case "101":
      return "Ceilings";
    default:
      return "Other";
  }
}

function getControlClasses(control: string) {
  switch (control) {
    case "EXTERNAL":
      return "bg-red-100 text-red-700 border-red-200";
    case "INTERNAL":
      return "bg-emerald-100 text-emerald-700 border-emerald-200";
    default:
      return "bg-slate-100 text-slate-600 border-slate-200";
  }
}

function getRiskClasses(risk: string) {
  switch (risk) {
    case "HIGH":
      return "bg-red-100 text-red-700 border-red-200";
    case "MEDIUM":
      return "bg-amber-100 text-amber-700 border-amber-200";
    case "LOW":
      return "bg-emerald-100 text-emerald-700 border-emerald-200";
    default:
      return "bg-slate-100 text-slate-600 border-slate-200";
  }
}

export default function DashboardPage() {
  const navigate = useNavigate();
  const [tasks, setTasks] = useState<any[]>([]);
  const [documents, setDocuments] = useState<any[]>([]);
  const [taskDocumentMap, setTaskDocumentMap] = useState<Record<string, any[]>>({});
  const [selectedTaskId, setSelectedTaskId] = useState<string>("");
  const [selectedDocumentName, setSelectedDocumentName] = useState<string>("");
  const [selectedFiles, setSelectedFiles] = useState<FileList | null>(null);
  const [uploading, setUploading] = useState(false);
  const [uploadResult, setUploadResult] = useState<any | null>(null);
  const [isLoading, setIsLoading] = useState(true);
  const [hasError, setHasError] = useState(false);
  const [contractFilter, setContractFilter] = useState("all");
  const [fitoutRisk, setFitoutRisk] = useState<any | null>(null);
  const [contractTaskCounts, setContractTaskCounts] = useState<any | null>(null);

  useEffect(() => {
    let mounted = true;

    async function ensureTestLogin() {
      const existingToken = localStorage.getItem("token");
      if (existingToken) return;

      const loginResponse = await api.post("/auth/login", {
        email: TEST_EMAIL,
        password: TEST_PASSWORD,
      });

      const accessToken = loginResponse?.data?.access_token;
      if (accessToken) {
        localStorage.setItem("token", accessToken);
        api.defaults.headers.common["Authorization"] = `Bearer ${accessToken}`;
      }
    }

    async function loadDashboard() {
      try {
        setIsLoading(true);
        setHasError(false);

        await ensureTestLogin();

        const [taskRes, documentRes, fitoutRiskRes, jobRes] = await Promise.all([
          api.get(`/tasks?job_id=${JOB_ID}`),
          api.get(`/jobs/${JOB_ID}/documents`),
          api.get(`/jobs/${JOB_ID}/fitout-risk`),
          api.get(`/jobs/${JOB_ID}`)
        ]);
          (taskRes.data || []).map(async (task: any) => {
            try {
              const res = await api.get(`/tasks/${task.id}/documents`);
              return [task.id, res.data?.documents || []];
            } catch {
              return [task.id, []];
            }
          })
        );

        const nextTaskDocumentMap = Object.fromEntries(taskDocsEntries);

        if (mounted) {
          setTasks(taskRes.data);
          setDocuments(documentRes.data?.files || []);
            setFitoutRisk(fitoutRiskRes.data);
            setContractTaskCounts(jobRes.data?.contract_task_counts || null);
          setTaskDocumentMap(nextTaskDocumentMap);
        }
      } catch (error) {
        if (mounted) setHasError(true);
      } finally {
        if (mounted) setIsLoading(false);
      }
    }

    loadDashboard();

    return () => {
      mounted = false;
    };
  }, []);

  if (isLoading) {
    return <div className="p-8 text-muted-foreground">Loading dashboard...</div>;
  }

  if (hasError) {
    return <div className="p-8 text-red-500">Failed to load dashboard</div>;
  }

  const taskMap: any = {};
  tasks.forEach((t) => {
    taskMap[t.id] = t;
  });

  const myTasks = tasks.filter((t) => t.task_code);

  function buildTaskView(t: any) {
    const predecessors = (t.predecessor_ids || [])
      .map((id: string) => taskMap[id]?.task_name)
      .filter(Boolean);

    const successors = tasks
      .filter((x) => (x.predecessor_ids || []).includes(t.id))
      .map((x) => x.task_name);

    let flag = "";
    let action = "";

    if (
      t.task_name?.toLowerCase().includes("insulation") &&
      predecessors.join(" ").toLowerCase().includes("stopping")
    ) {
      flag = "SEQUENCE ISSUE";
      action = "Move insulation earlier";
    } else if (successors.length > 1) {
      flag = "PARALLEL OPPORTUNITY";
      action = "Split crews / overlap work";
    } else if (!predecessors.length && t.task_name?.toLowerCase().includes("framing")) {
      flag = "STARTING TASK";
      action = "Confirm ready to start";
    } else if (successors.join(" ").toLowerCase().includes("wall linings")) {
      flag = "DRIVES NEXT TRADE";
      action = "Protect finish date";
    } else if (successors.join(" ").toLowerCase().includes("stopping")) {
      flag = "FINISH CRITICAL";
      action = "Quality handoff critical";
    }

    const predText = predecessors.join(" ").toLowerCase();
    const taskText = `${t.task_name || ""} ${t.owner_party || ""}`.toLowerCase();

    let control = "INTERNAL";
    let risk = "LOW";
    let riskNote = "Within your direct trade control.";

    if (
      !predecessors.length &&
      (taskText.includes("framing") ||
        taskText.includes("stud") ||
        taskText.includes("partition"))
    ) {
      control = "EXTERNAL";
      risk = "HIGH";
      riskNote = "Start depends on base build readiness, access, and released work fronts.";
    } else if (
      predText.includes("concrete") ||
      predText.includes("slab") ||
      predText.includes("structure") ||
      predText.includes("purlin") ||
      predText.includes("steel")
    ) {
      control = "EXTERNAL";
      risk = "HIGH";
      riskNote = "Predecessor appears base build or structural. Confirm readiness before committing labour.";
    } else if (
      flag === "SEQUENCE ISSUE"
    ) {
      control = "INTERNAL";
      risk = "HIGH";
      riskNote = "Current task order looks wrong for fitout sequence and may create rework or LD exposure.";
    } else if (
      flag === "PARALLEL OPPORTUNITY" ||
      flag === "FINISH CRITICAL"
    ) {
      control = "INTERNAL";
      risk = "MEDIUM";
      riskNote = "Monitor handoff quality and use split crews if needed to protect dates.";
    }

    let ldExposure = "LOW";
    if (risk === "HIGH" && control === "EXTERNAL") {
      ldExposure = "HIGH";
    } else if (risk === "HIGH" || flag === "FINISH CRITICAL") {
      ldExposure = "MEDIUM";
    }

    return {
      ...t,
      tradeBucket: getTradeBucket(t.task_code),
      predecessors,
      successors,
      flag,
      action,
      control,
      risk,
      riskNote,
      ldExposure,
    };
  }

  const filteredMyTasks = contractFilter === "all"
    ? myTasks
    : myTasks.filter((t: any) => (t.contract_type || "").toLowerCase() === contractFilter.toLowerCase());

  const myTaskView = filteredMyTasks.map(buildTaskView);

  const groupedTasks = myTaskView.reduce((acc: Record<string, any[]>, task: any) => {
    if (!acc[task.tradeBucket]) {
      acc[task.tradeBucket] = [];
    }
    acc[task.tradeBucket].push(task);
    return acc;
  }, {});

  const bucketOrder = ["Framing", "Linings", "Fire Rating", "Stopping", "Ceilings", "Insulation", "Other"];
  const visibleBuckets = bucketOrder.filter((bucket) => groupedTasks[bucket]?.length);

  const highLdTasks = myTaskView.filter((t) => t.ldExposure === "HIGH");

  async function handleUpload() {
    if (!selectedFiles || selectedFiles.length === 0) return;

    try {
      setUploading(true);
      setUploadResult(null);

      const formData = new FormData();
      Array.from(selectedFiles).forEach((file) => {
        formData.append("files", file);
      });

      const token = localStorage.getItem("token");

      const response = await fetch(`http://127.0.0.1:8010/api/jobs/${JOB_ID}/documents/upload`, {
        method: "POST",
        headers: token ? { Authorization: `Bearer ${token}` } : undefined,
        body: formData,
      });

      const data = await response.json();
      setUploadResult(data);

      const documentRes = await api.get(`/jobs/${JOB_ID}/documents`);
      setDocuments(documentRes.data?.files || []);
      setSelectedFiles(null);
    } catch (error) {
      setUploadResult({ error: "Upload failed" });
    } finally {
      setUploading(false);
    }
  }

  async function handleAttachDocument() {
    if (!selectedTaskId || !selectedDocumentName) return;

    try {
      const token = localStorage.getItem("token");

      await fetch(`http://127.0.0.1:8010/api/tasks/${selectedTaskId}/documents/link`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          ...(token ? { Authorization: `Bearer ${token}` } : {}),
        },
        body: JSON.stringify({
          job_id: JOB_ID,
          filename: selectedDocumentName
        }),
      });

      const res = await api.get(`/tasks/${selectedTaskId}/documents`);

      setTaskDocumentMap((prev) => ({
        ...prev,
        [selectedTaskId]: res.data?.documents || [],
      }));

      setSelectedTaskId("");
      setSelectedDocumentName("");
    } catch (error) {
      console.error("Attach document failed", error);
    }
  }

  return (
    <div className="p-8 space-y-8 max-w-7xl mx-auto">
        <div className="flex gap-2 mb-4">
          {["all","base_build","fitout","shared"].map((c) => (
            <button
              key={c}
              onClick={() => setContractFilter(c)}
              className={`px-3 py-1 rounded-lg border ${
                contractFilter === c
                  ? "bg-black text-white"
                  : "bg-white text-black"
              }`}
            >
              {c.toUpperCase()}
            </button>
          ))}
        </div>
      <div className="space-y-1">
        <h1 className="text-3xl font-semibold tracking-tight text-slate-900">My Task Dashboard</h1>
        <p className="text-sm text-slate-500">
          Trade-only view. Direct predecessors, direct impacts, sequence issues, external dependency risk, and acceleration opportunities.
        </p>
      </div>

        <Card className="border-slate-200 bg-white shadow-sm">
          <CardHeader>
            <CardTitle className="text-xl text-slate-900">Fitout LD Risk</CardTitle>
          </CardHeader>
          <CardContent className="space-y-2 text-sm text-slate-800">
            <div><span className="font-semibold text-slate-900">Risk Band:</span> {fitoutRisk?.risk_band || "unknown"}</div>
            <div><span className="font-semibold text-slate-900">LD Exposure:</span> {fitoutRisk?.ld_exposure ? "Yes" : "No"}</div>
            <div><span className="font-semibold text-slate-900">Fitout Tasks:</span> {fitoutRisk?.fitout_task_count ?? 0}</div>
            <div><span className="font-semibold text-slate-900">Critical Fitout Tasks:</span> {fitoutRisk?.fitout_critical_count ?? 0}</div>
            <div><span className="font-semibold text-slate-900">Total Fitout Float:</span> {fitoutRisk?.total_fitout_float_days ?? 0} days</div>
          </CardContent>
        </Card>


      <Card className="border-slate-200 bg-white shadow-sm">
        <CardHeader>
          <CardTitle className="text-xl text-slate-900">Documents</CardTitle>
        </CardHeader>
        <CardContent className="space-y-4">
          <input
            type="file"
            multiple
            onChange={(e) => setSelectedFiles(e.target.files)}
            className="block w-full text-sm text-slate-700"
          />
          <button
            onClick={handleUpload}
            disabled={uploading || !selectedFiles || selectedFiles.length === 0}
            className="inline-flex items-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white disabled:opacity-50"
          >
            {uploading ? "Uploading..." : "Upload Files"}
          </button>

          {uploadResult && (
            <div className="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700">
              <pre className="whitespace-pre-wrap break-words">{JSON.stringify(uploadResult, null, 2)}</pre>
            </div>
          )}

          <div className="space-y-4">
            <div className="rounded-md border border-slate-200 bg-slate-50 p-4 space-y-3">
              <div className="text-sm font-semibold text-slate-900">Attach Document to Task</div>

              <select
                value={selectedTaskId}
                onChange={(e) => setSelectedTaskId(e.target.value)}
                className="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900"
              >
                <option value="">Select task</option>
                {myTaskView.map((task) => (
                  <option key={task.id} value={task.id}>
                    {task.task_code} - {task.task_name}
                  </option>
                ))}
              </select>

              <select
                value={selectedDocumentName}
                onChange={(e) => setSelectedDocumentName(e.target.value)}
                className="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900"
              >
                <option value="">Select document</option>
                {documents.map((doc, index) => (
                  <option key={`${doc.filename}-${index}`} value={doc.filename}>
                    {doc.filename}
                  </option>
                ))}
              </select>

              <button
                onClick={handleAttachDocument}
                disabled={!selectedTaskId || !selectedDocumentName}
                className="inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white disabled:opacity-50"
              >
                Attach to Task
              </button>
            </div>

            <div className="space-y-2">
              <div className="text-sm font-semibold text-slate-900">Uploaded Documents</div>

              {documents.length === 0 ? (
                <div className="text-sm text-slate-500">No documents uploaded yet.</div>
              ) : (
                <div className="space-y-2">
                  {documents.map((doc, index) => (
                    <div
                      key={`${doc.filename}-${index}`}
                      className="rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 cursor-pointer hover:bg-slate-100 shadow-sm"
                      onClick={() => window.open(`http://127.0.0.1:8010/api/jobs/${JOB_ID}/documents/${doc.filename}`, "_blank")}
                    >
                      {doc.filename} ({(doc.size_bytes / 1024).toFixed(1)} KB)
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        </CardContent>
      </Card>

      <Card className="border border-red-200 bg-red-50/50 shadow-sm">
        <CardHeader className="pb-3">
          <CardTitle className="text-xl text-red-900">LD Risk Watch</CardTitle>
          <div className="text-sm text-red-700">
            {highLdTasks.length} task{highLdTasks.length === 1 ? "" : "s"} currently flagged with high LD exposure
          </div>
        </CardHeader>
        <CardContent className="space-y-3">
          {highLdTasks.length === 0 ? (
            <div className="text-sm text-red-700">No high LD exposure tasks currently flagged.</div>
          ) : (
            highLdTasks.map((t: any) => (
              <div key={t.id} className="rounded-xl border border-red-200 bg-white/90 p-3">
                <div className="font-medium text-slate-900">{t.task_name}</div>
                <div className="text-sm text-slate-600">{t.planned_start} → {t.planned_finish}</div>
                <div className="mt-1 text-sm text-red-700">{t.riskNote}</div>
              </div>
            ))
          )}
        </CardContent>
      </Card>

      <Card className="border border-border/60 shadow-sm">
        <CardHeader className="pb-3">
          <CardTitle className="text-xl">My Tasks (Trade View)</CardTitle>
          <div className="text-sm text-muted-foreground">
            {myTaskView.length} mapped trade tasks
          </div>
        </CardHeader>
        <CardContent className="space-y-8">
          {visibleBuckets.map((bucket) => (
            <div key={bucket} className="space-y-4">
              <div className="flex items-center gap-3">
                <div className="text-base font-semibold text-slate-900">{bucket}</div>
                <div className="h-px flex-1 bg-border/70" />
                <div className="text-xs uppercase tracking-wide text-slate-500">
                  {groupedTasks[bucket].length} task{groupedTasks[bucket].length === 1 ? "" : "s"}
                </div>
              </div>

              <div className="grid gap-4">
                {groupedTasks[bucket].map((t: any) => {
                  const flagStyles = getFlagClasses(t.flag);

                  return (
                    <div
                      key={t.id}
                      className={`rounded-2xl border p-5 shadow-sm transition hover:shadow-md hover:-translate-y-[1px] cursor-pointer ${flagStyles.card}`}
                      onClick={() => navigate(`/tasks/${t.id}`)}
                    >
                      <div className="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                        <div className="space-y-2 min-w-0">
                          <div className="flex flex-wrap items-center gap-2">
                            <span className={`inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold ${getCodeClasses(t.task_code)}`}>
                              {t.task_code}
                            </span>

                            {t.flag && (
                              <span className={`inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-semibold ${flagStyles.badge}`}>
                                {t.flag}
                              </span>
                            )}

                            <span className={`inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-semibold ${getControlClasses(t.control)}`}>
                              {t.control}
                            </span>

                            <span className={`inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-semibold ${getRiskClasses(t.risk)}`}>
                              RISK {t.risk}
                            </span>

                            <span className={`inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-semibold ${getRiskClasses(t.ldExposure)}`}>
                              LD {t.ldExposure}
                            </span>
                          </div>

                          <div className="text-lg font-semibold text-slate-900 leading-snug">
                            {t.task_name}
                          </div>

                          <div className="text-sm text-slate-500">
                            {t.planned_start} → {t.planned_finish}
                          </div>
                        </div>

                        <div className="text-xs uppercase tracking-wide text-slate-500 shrink-0">
                          {t.tradeBucket}
                        </div>
                      </div>

                      <div className="mt-4 grid gap-3 md:grid-cols-2">
                        <div className="rounded-xl border border-border/60 bg-white/80 p-3">
                          <div className="text-[11px] uppercase tracking-wide text-slate-500 mb-1">
                            Driven by
                          </div>
                          <div className="text-sm text-slate-800">
                            {t.predecessors.length ? t.predecessors.join(", ") : "-"}
                          </div>
                        </div>

                        <div className="rounded-xl border border-border/60 bg-white/80 p-3">
                          <div className="text-[11px] uppercase tracking-wide text-slate-500 mb-1">
                            Drives
                          </div>
                          <div className="text-sm text-slate-800">
                            {t.successors.length ? t.successors.join(", ") : "-"}
                          </div>
                        </div>
                      </div>

                      <div className="mt-4 rounded-xl border border-border/60 bg-white/80 p-3">
                        <div className="text-[11px] uppercase tracking-wide text-slate-500 mb-1">
                          Dependency risk note
                        </div>
                        <div className="text-sm text-slate-800">
                          {t.riskNote}

                          <div className="mt-2 text-xs text-slate-500">
                            {t.documentCount > 0
                              ? `${t.documentCount} document${t.documentCount === 1 ? "" : "s"} linked`
                              : "No documents linked"}
                          </div>
                        </div>
                      </div>

                      {t.action && (
                        <div className="mt-4 rounded-xl border border-border/60 bg-white/80 p-3">
                          <div className="text-[11px] uppercase tracking-wide text-slate-500 mb-1">
                            Recommended action
                          </div>
                          <div className={`text-sm font-medium ${flagStyles.action}`}>
                            {t.action}
                          </div>
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </CardContent>
      </Card>
    </div>
  );
}














