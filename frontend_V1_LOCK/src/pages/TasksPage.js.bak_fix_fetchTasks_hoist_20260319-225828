// Gantt Chart Component with Drag-and-Drop
const GanttChart = ({ tasks, jobs, startDate, endDate, onTaskClick, onTaskUpdate, canEdit }) => {
  const containerRef = useRef(null);
  const [dragState, setDragState] = useState(null);
  const [hoveredDay, setHoveredDay] = useState(null);
  
  const days = useMemo(() => {
    return eachDayOfInterval({ start: startDate, end: endDate });
  }, [startDate, endDate]);

  const totalDays = days.length;
  const dayWidth = 100 / totalDays;

  const getTaskPosition = (task, overrideStart = null) => {
    const taskStartDate = overrideStart || task.planned_start;
    if (!taskStartDate) return null;
    
    const taskStart = typeof taskStartDate === 'string' ? parseISO(taskStartDate) : taskStartDate;
    const duration = task.duration_days || differenceInDays(
      task.planned_finish ? parseISO(task.planned_finish) : addDays(taskStart, 1),
      typeof task.planned_start === 'string' ? parseISO(task.planned_start) : task.planned_start
    ) + 1;
    const taskEnd = addDays(taskStart, duration - 1);

    // Check if task is within view
    if (isAfter(taskStart, endDate) || isBefore(taskEnd, startDate)) {
      return null;
    }

    const effectiveStart = isBefore(taskStart, startDate) ? startDate : taskStart;
    const effectiveEnd = isAfter(taskEnd, endDate) ? endDate : taskEnd;

    const startOffset = differenceInDays(effectiveStart, startDate);
    const durationDays = differenceInDays(effectiveEnd, effectiveStart) + 1;

    return {
      left: `${startOffset * dayWidth}%`,
      width: `${durationDays * dayWidth}%`,
      startOffset,
      duration: durationDays,
    };
  };

  const getStatusColor = (status, isDragging = false) => {
    const baseColors = {
      complete: 'bg-green-500',
      active: 'bg-blue-500',
      blocked: 'bg-red-500',
      delayed: 'bg-orange-500',
      at_risk: 'bg-amber-500',
      default: 'bg-slate-400',
    };
    const color = baseColors[status] || baseColors.default;
    return isDragging ? `${color} opacity-70 ring-2 ring-primary ring-offset-2` : color;
  };

  const getJobName = (jobId) => {
    const job = jobs.find(j => j.id === jobId);
    return job ? job.job_number : '';
  };

  // Group tasks by job
  const tasksByJob = useMemo(() => {
    const grouped = {};
    tasks.forEach(task => {
      if (!grouped[task.job_id]) {
        grouped[task.job_id] = [];
      }
      grouped[task.job_id].push(task);
    });
    return grouped;
  }, [tasks]);

  // Drag handlers
  const handleDragStart = useCallback((e, task) => {
    if (!canEdit || !task.planned_start) return;
    e.preventDefault();
    e.stopPropagation();
    
    const rect = containerRef.current?.getBoundingClientRect();
    if (!rect) return;

    const taskListWidth = 256; // w-64 = 16rem = 256px
    const timelineWidth = rect.width - taskListWidth;
    const dayPixelWidth = timelineWidth / totalDays;
    
    setDragState({
      task,
      startX: e.clientX,
      originalStart: parseISO(task.planned_start),
      dayPixelWidth,
      timelineLeft: rect.left + taskListWidth,
    });
  }, [canEdit, totalDays]);

  const handleDragMove = useCallback((e) => {
    if (!dragState) return;
    
    const deltaX = e.clientX - dragState.startX;
    const daysDelta = Math.round(deltaX / dragState.dayPixelWidth);
    const newStart = addDays(dragState.originalStart, daysDelta);
    
    setHoveredDay(newStart);
  }, [dragState]);

  const handleDragEnd = useCallback(async () => {
    if (!dragState || !hoveredDay) {
      setDragState(null);
      setHoveredDay(null);
      return;
    }

    const task = dragState.task;
    const originalStart = dragState.originalStart;
    const daysDelta = differenceInDays(hoveredDay, originalStart);
    
    if (daysDelta === 0) {
      setDragState(null);
      setHoveredDay(null);
      return;
    }

    // Calculate new dates
    const newStart = hoveredDay;
    const duration = task.duration_days || differenceInDays(
      parseISO(task.planned_finish),
      parseISO(task.planned_start)
    ) + 1;
    const newEnd = addDays(newStart, duration - 1);

    setDragState(null);
    setHoveredDay(null);

    // Call parent to handle update
    if (onTaskUpdate) {
      await onTaskUpdate(task, {
        planned_start: format(newStart, 'yyyy-MM-dd'),
        planned_finish: format(newEnd, 'yyyy-MM-dd'),
        daysDelta,
      });
    }
  }, [dragState, hoveredDay, onTaskUpdate]);

  // Global mouse event handlers
  useEffect(() => {
    if (!dragState) return;

    const handleMouseMove = (e) => handleDragMove(e);
    const handleMouseUp = () => handleDragEnd();

    document.addEventListener('mousemove', handleMouseMove);
    document.addEventListener('mouseup', handleMouseUp);

    return () => {
      document.removeEventListener('mousemove', handleMouseMove);
      document.removeEventListener('mouseup', handleMouseUp);
    };
  }, [dragState, handleDragMove, handleDragEnd]);

  return (
    <div className="overflow-x-auto" ref={containerRef}>
      {/* Drag indicator */}
      {dragState && hoveredDay && (
        <div className="fixed top-4 left-1/2 -translate-x-1/2 z-50 bg-primary text-primary-foreground px-4 py-2 rounded-full shadow-lg flex items-center gap-2">
          <Move className="h-4 w-4" />
          <span className="font-medium">
            Moving to {format(hoveredDay, 'MMM d, yyyy')}
          </span>
          <span className="text-xs opacity-80">
            ({differenceInDays(hoveredDay, dragState.originalStart) > 0 ? '+' : ''}
            {differenceInDays(hoveredDay, dragState.originalStart)} days)
          </span>
        </div>
      )}

      {/* Header with dates */}
      <div className="flex border-b border-border sticky top-0 bg-background z-10">
        <div className="w-64 flex-shrink-0 p-2 border-r border-border font-medium text-sm">
          Task
        </div>
        <div className="flex-1 flex">
          {days.map((day, index) => (
            <div
              key={index}
              className={cn(
                "flex-1 min-w-[40px] p-1 text-center text-xs border-r border-border/50",
                format(day, 'E') === 'Sat' || format(day, 'E') === 'Sun' 
                  ? 'bg-muted/50' 
                  : '',
                hoveredDay && format(hoveredDay, 'yyyy-MM-dd') === format(day, 'yyyy-MM-dd')
                  ? 'bg-primary/20'
                  : ''
              )}
            >
              <div className="font-medium">{format(day, 'EEE')}</div>
              <div className="text-muted-foreground">{format(day, 'd')}</div>
            </div>
          ))}
        </div>
      </div>

      {/* Task rows grouped by job */}
      {Object.entries(tasksByJob).map(([jobId, jobTasks]) => (
        <div key={jobId}>
          {/* Job header row */}
          <div className="flex bg-muted/30 border-b border-border">
            <div className="w-64 flex-shrink-0 p-2 border-r border-border font-medium text-sm flex items-center gap-2">
              <Badge variant="outline" className="font-mono">
                {getJobName(jobId)}
              </Badge>
              <span className="text-muted-foreground text-xs">
                {jobTasks.length} tasks
              </span>
            </div>
            <div className="flex-1" />
          </div>

          {/* Task rows */}
          {jobTasks.map((task) => {
            const isDragging = dragState?.task.id === task.id;
            const displayStart = isDragging && hoveredDay ? hoveredDay : null;
            const position = getTaskPosition(task, displayStart);
            
            return (
              <div 
                key={task.id} 
                className={cn(
                  "flex border-b border-border/50 hover:bg-accent/30",
                  isDragging ? 'bg-accent/50' : '',
                  !isDragging && 'cursor-pointer'
                )}
                onClick={() => !isDragging && onTaskClick?.(task)}
              >
                <div className="w-64 flex-shrink-0 p-2 border-r border-border">
                  <div className="flex items-center gap-2">
                    <span className={cn(
                      "w-2 h-2 rounded-full flex-shrink-0",
                      getStatusColor(task.status)
                    )} />
                    <span className="text-sm truncate">{task.task_name}</span>
                    {canEdit && task.planned_start && (
                      <GripVertical className="h-3 w-3 text-muted-foreground opacity-0 group-hover:opacity-100" />
                    )}
                  </div>
                  {task.zone_area && (
                    <span className="text-xs text-muted-foreground ml-4">{task.zone_area}</span>
                  )}
                </div>
                <div className="flex-1 relative h-12 group">
                  {/* Grid lines */}
                  <div className="absolute inset-0 flex">
                    {days.map((day, index) => (
                      <div
                        key={index}
                        className={cn(
                          "flex-1 border-r border-border/30",
                          format(day, 'E') === 'Sat' || format(day, 'E') === 'Sun' 
                            ? 'bg-muted/30' 
                            : ''
                        )}
                      />
                    ))}
                  </div>
                  
                  {/* Task bar */}
                  {position && (
                    <TooltipProvider>
                      <Tooltip delayDuration={isDragging ? 999999 : 300}>
                        <TooltipTrigger asChild>
                          <div
                            className={cn(
                              "absolute top-2 h-8 rounded-md flex items-center justify-center text-white text-xs font-medium transition-all",
                              getStatusColor(task.status, isDragging),
                              canEdit && task.planned_start && "cursor-grab active:cursor-grabbing hover:ring-2 hover:ring-primary/50"
                            )}
                            style={{
                              left: position.left,
                              width: position.width,
                              minWidth: '20px',
                            }}
                            onMouseDown={(e) => handleDragStart(e, task)}
                          >
                            {canEdit && task.planned_start && (
                              <GripVertical className="h-3 w-3 absolute left-1 opacity-50" />
                            )}
                            {task.percent_complete > 0 && (
                              <span>{task.percent_complete}%</span>
                            )}
                          </div>
                        </TooltipTrigger>
                        <TooltipContent>
                          <div className="space-y-1">
                            <p className="font-medium">{task.task_name}</p>
                            <p className="text-xs">
                              {task.planned_start && format(parseISO(task.planned_start), 'MMM d')}
                              {task.planned_finish && ` - ${format(parseISO(task.planned_finish), 'MMM d')}`}
                            </p>
                            <p className="text-xs capitalize">{task.status}</p>
                            {task.quoted_hours && (
                              <p className="text-xs">{task.quoted_hours}h quoted</p>
                            )}
                            {canEdit && (
                              <p className="text-xs text-muted-foreground mt-2">
                                Drag to reschedule
                              </p>
                            )}
                          </div>
                        </TooltipContent>
                      </Tooltip>
                    </TooltipProvider>
                  )}
                  
                  {/* No dates indicator */}
                  {!position && !task.planned_start && (
                    <div className="absolute inset-0 flex items-center justify-center">
                      <span className="text-xs text-muted-foreground">No dates set</span>
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      ))}
    </div>
  );
};

export default function TasksPage() {
  const { canManage } = useAuth();
  const [tasks, setTasks] = useState([]);
  const [jobs, setJobs] = useState([]);
  const [selectedJob, setSelectedJob] = useState('all');
  const [loading, setLoading] = useState(true);
  const [viewMode, setViewMode] = useState('list'); // 'list' or 'gantt'
  
  // Gantt date range
  const [ganttStart, setGanttStart] = useState(() => startOfWeek(new Date(), { weekStartsOn: 1 }));
  const [ganttWeeks, setGanttWeeks] = useState(4);

  // Reschedule dialog state
  const [rescheduleDialog, setRescheduleDialog] = useState(null);
  const [impactAnalysis, setImpactAnalysis] = useState(null);
  const [savingReschedule, setSavingReschedule] = useState(false);

  const ganttEnd = useMemo(() => addDays(ganttStart, ganttWeeks * 7 - 1), [ganttStart, ganttWeeks]);

  useEffect(() => {
    fetchData();
  }, []);

  useEffect(() => {
    fetchTasks();
  }, [fetchTasks]);

  const fetchData = async () => {
    try {
      const [tasksRes, jobsRes] = await Promise.all([
        api.get('/tasks'),
        api.get('/jobs'),
      ]);
      setTasks(tasksRes.data);
      setJobs(jobsRes.data);
    } catch (error) {
      toast.error('Failed to load data');
    } finally {
      setLoading(false);
    }
  };

  const fetchTasks = useCallback(async () => {
    try {
      const url = selectedJob === 'all' ? '/tasks' : `/tasks?job_id=${selectedJob}`;
      const response = await api.get(url);
      setTasks(response.data);
    } catch (error) {
      toast.error('Failed to load tasks');
    }
  }, [selectedJob]);

  const navigateGantt = (direction) => {
    if (direction === 'prev') {
      setGanttStart(subWeeks(ganttStart, 1));
    } else {
      setGanttStart(addWeeks(ganttStart, 1));
    }
  };

  const goToToday = () => {
    setGanttStart(startOfWeek(new Date(), { weekStartsOn: 1 }));
  };

  // Handle task reschedule from Gantt drag-and-drop
  const handleTaskReschedule = async (task, newDates) => {
    // Fetch impact analysis first
    try {
      const impactRes = await api.get(`/delays/impact-analysis/${task.id}?delay_days=${Math.abs(newDates.daysDelta)}`);
      setImpactAnalysis(impactRes.data);
    } catch (error) {
      // If impact analysis fails, proceed without it
      setImpactAnalysis(null);
    }

    setRescheduleDialog({
      task,
      newDates,
      originalStart: task.planned_start,
      originalFinish: task.planned_finish,
    });
  };

  const confirmReschedule = async () => {
    if (!rescheduleDialog) return;

    setSavingReschedule(true);
    const { task, newDates } = rescheduleDialog;

    try {
      // Build update payload preserving existing task data
      const payload = {
        job_id: task.job_id,
        task_name: task.task_name,
        task_type: task.task_type || null,
        linked_task_codes: task.linked_task_codes || [],
        planned_start: newDates.planned_start,
        planned_finish: newDates.planned_finish,
        actual_start: task.actual_start || null,
        actual_finish: task.actual_finish || null,
        duration_days: task.duration_days || null,
        predecessor_ids: task.predecessor_ids || [],
        owner_party: task.owner_party || null,
        is_internal: task.is_internal,
        subcontractor_id: task.subcontractor_id || null,
        zone_area: task.zone_area || null,
        status: task.status,
        blockers: task.blockers || null,
        notes: task.notes || null,
        quoted_hours: task.quoted_hours || null,
        percent_complete: task.percent_complete || 0,
      };

      await api.put(`/tasks/${task.id}`, payload);
      
      // Update local state
      setTasks(tasks.map(t => 
        t.id === task.id 
          ? { ...t, planned_start: newDates.planned_start, planned_finish: newDates.planned_finish }
          : t
      ));

      const direction = newDates.daysDelta > 0 ? 'forward' : 'back';
      toast.success(`Task rescheduled ${Math.abs(newDates.daysDelta)} day${Math.abs(newDates.daysDelta) > 1 ? 's' : ''} ${direction}`);
      
      setRescheduleDialog(null);
      setImpactAnalysis(null);
    } catch (error) {
      toast.error(error.response?.data?.detail || 'Failed to reschedule task');
    } finally {
      setSavingReschedule(false);
    }
  };

  
  const toggleLock = async (task) => {
    try {

      const payload = {
        job_id: task.job_id,
        task_name: task.task_name,
        task_type: task.task_type || null,
        linked_task_codes: task.linked_task_codes || [],
        planned_start: task.planned_start,
        planned_finish: task.planned_finish,
        actual_start: task.actual_start || null,
        actual_finish: task.actual_finish || null,
        duration_days: task.duration_days || null,
        predecessor_ids: task.predecessor_ids || [],
        owner_party: task.owner_party || null,
        is_internal: task.is_internal,
        subcontractor_id: task.subcontractor_id || null,
        zone_area: task.zone_area || null,
        status: task.status,
        blockers: task.blockers || null,
        notes: task.notes || null,
        quoted_hours: task.quoted_hours || null,
        percent_complete: task.percent_complete || 0,
        locked: !task.locked
      }

      await api.put(`/tasks/${task.id}`, payload)

      setTasks(tasks.map(t =>
        t.id === task.id ? { ...t, locked: !t.locked } : t
      ))

    } catch (e) {
      toast.error("Failed to toggle lock")
    }
  }
const cancelReschedule = () => {
    setRescheduleDialog(null);
    setImpactAnalysis(null);
  };

  const getStatusIcon = (status) => {
    switch (status) {
      case 'complete': return <CheckCircle className="h-4 w-4 text-green-500" />;
      case 'active': return <Clock className="h-4 w-4 text-blue-500" />;
      case 'blocked': return <XCircle className="h-4 w-4 text-red-500" />;
      case 'delayed': return <AlertTriangle className="h-4 w-4 text-orange-500" />;
      default: return <Calendar className="h-4 w-4 text-muted-foreground" />;
    }
  };

  const getStatusBadgeVariant = (status) => {
    switch (status) {
      case 'complete': return 'success';
      case 'active': return 'default';
      case 'blocked': return 'destructive';
      case 'delayed': return 'warning';
      case 'at_risk': return 'warning';
      default: return 'secondary';
    }
  };

  const getJobName = (jobId) => {
    const job = jobs.find(j => j.id === jobId);
    return job ? `${job.job_number}` : 'Unknown';
  };

  // Group tasks by status for overview
  const tasksByStatus = tasks.reduce((acc, task) => {
    acc[task.status] = (acc[task.status] || 0) + 1;
    return acc;
  }, {});

  // Identify at-risk tasks (starting soon with issues)
  const atRiskTasks = useMemo(() => {
    const now = new Date();
    const weekFromNow = addDays(now, 7);
    
    return tasks.filter(task => {
      if (!task.planned_start) return false;
      const startDate = parseISO(task.planned_start);
      return isWithinInterval(startDate, { start: now, end: weekFromNow }) &&
             (task.status === 'planned' || task.status === 'blocked' || task.status === 'delayed');
    });
  }, [tasks]);

  return (
    <div className="space-y-6" data-testid="tasks-page">
      {/* Header */}
      <div className="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h1 className="text-3xl font-bold font-['Manrope']">Tasks</h1>
          <p className="text-muted-foreground mt-1">View and manage project tasks</p>
        </div>
        <div className="flex items-center gap-2">
          {/* View Toggle */}
          <div className="flex border rounded-lg p-1">
            <Button
              variant={viewMode === 'list' ? 'default' : 'ghost'}
              size="sm"
              onClick={() => setViewMode('list')}
              data-testid="list-view-btn"
            >
              <LayoutList className="h-4 w-4 mr-1" />
              List
            </Button>
            <Button
              variant={viewMode === 'gantt' ? 'default' : 'ghost'}
              size="sm"
              onClick={() => setViewMode('gantt')}
              data-testid="gantt-view-btn"
            >
              <GanttChartIcon className="h-4 w-4 mr-1" />
              Gantt
            </Button>
          </div>
          
          <Filter className="h-4 w-4 text-muted-foreground" />
          <Select value={selectedJob} onValueChange={setSelectedJob}>
            <SelectTrigger className="w-[250px]" data-testid="job-filter">
              <SelectValue placeholder="Filter by job" />
            </SelectTrigger>
            <SelectContent>
              <SelectItem value="all">All Jobs</SelectItem>
              {jobs.map((job) => (
                <SelectItem key={job.id} value={job.id}>
                  {job.job_number} - {job.job_name}
                </SelectItem>
              ))}
            </SelectContent>
          </Select>
        </div>
      </div>

      {/* At Risk Alert */}
      {atRiskTasks.length > 0 && (
        <div className="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4">
          <div className="flex items-start gap-3">
            <AlertCircle className="h-5 w-5 text-amber-500 flex-shrink-0 mt-0.5" />
            <div>
              <p className="font-medium text-amber-800 dark:text-amber-200">
                {atRiskTasks.length} task{atRiskTasks.length > 1 ? 's' : ''} starting soon need attention
              </p>
              <ul className="mt-2 space-y-1">
                {atRiskTasks.slice(0, 3).map(task => (
                  <li key={task.id} className="text-sm text-amber-700 dark:text-amber-300 flex items-center gap-2">
                    <span className="font-mono text-xs">{getJobName(task.job_id)}</span>
                    <span>{task.task_name}</span>
                    <Badge variant="outline" className="text-xs">{task.status}</Badge>
                  </li>
                ))}
                {atRiskTasks.length > 3 && (
                  <li className="text-sm text-amber-600">
                    + {atRiskTasks.length - 3} more
                  </li>
                )}
              </ul>
            </div>
          </div>
        </div>
      )}

      {/* Status Overview */}
      <div className="grid gap-4 md:grid-cols-5">
        {[
          { status: 'planned', label: 'Planned', color: 'bg-slate-500' },
          { status: 'active', label: 'Active', color: 'bg-blue-500' },
          { status: 'complete', label: 'Complete', color: 'bg-green-500' },
          { status: 'blocked', label: 'Blocked', color: 'bg-red-500' },
          { status: 'delayed', label: 'Delayed', color: 'bg-orange-500' },
        ].map(({ status, label, color }) => (
          <Card key={status}>
            <CardContent className="pt-6">
              <div className="flex items-center justify-between">
                <div>
                  <p className="text-sm text-muted-foreground">{label}</p>
                  <p className="font-data text-2xl font-bold">{tasksByStatus[status] || 0}</p>
                </div>
                <div className={`w-3 h-12 rounded-full ${color}`} />
              </div>
            </CardContent>
          </Card>
        ))}
      </div>

      {/* Main Content */}
      {viewMode === 'gantt' ? (
        /* Gantt View */
        <Card>
          <CardHeader className="pb-2">
            <div className="flex items-center justify-between">
              <div>
                <CardTitle className="text-lg">Gantt Chart</CardTitle>
                <CardDescription>
                  {format(ganttStart, 'MMM d')} - {format(ganttEnd, 'MMM d, yyyy')}
                </CardDescription>
              </div>
              <div className="flex items-center gap-2">
                <Select 
                  value={ganttWeeks.toString()} 
                  onValueChange={(v) => setGanttWeeks(parseInt(v))}
                >
                  <SelectTrigger className="w-[120px]">
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="2">2 weeks</SelectItem>
                    <SelectItem value="4">4 weeks</SelectItem>
                    <SelectItem value="6">6 weeks</SelectItem>
                    <SelectItem value="8">8 weeks</SelectItem>
                  </SelectContent>
                </Select>
                <Button variant="outline" size="icon" onClick={() => navigateGantt('prev')}>
                  <ChevronLeft className="h-4 w-4" />
                </Button>
                <Button variant="outline" size="sm" onClick={goToToday}>
                  Today
                </Button>
                <Button variant="outline" size="icon" onClick={() => navigateGantt('next')}>
                  <ChevronRight className="h-4 w-4" />
                </Button>
              </div>
            </div>
          </CardHeader>
          <CardContent className="p-0">
            {loading ? (
              <div className="flex items-center justify-center py-12">
                <Loader2 className="h-8 w-8 animate-spin text-primary" />
              </div>
            ) : tasks.length === 0 ? (
              <div className="text-center py-12">
                <ListTodo className="h-12 w-12 mx-auto text-muted-foreground/50 mb-4" />
                <h3 className="text-lg font-medium">No tasks found</h3>
                <p className="text-muted-foreground mt-2">
                  Create tasks from the job detail page
                </p>
              </div>
            ) : (
              <GanttChart
                tasks={tasks}
                jobs={jobs}
                startDate={ganttStart}
                endDate={ganttEnd}
                canEdit={canManage()}
                onTaskUpdate={handleTaskReschedule}
              />
            )}
          </CardContent>
        </Card>
      ) : (
        /* List View */
        <Card>
          <CardHeader>
            <CardTitle className="text-lg">All Tasks</CardTitle>
            <CardDescription>
              {tasks.length} task{tasks.length !== 1 ? 's' : ''} total
            </CardDescription>
          </CardHeader>
          <CardContent>
            {loading ? (
              <div className="flex items-center justify-center py-12">
                <Loader2 className="h-8 w-8 animate-spin text-primary" />
              </div>
            ) : tasks.length === 0 ? (
              <div className="text-center py-12">
                <ListTodo className="h-12 w-12 mx-auto text-muted-foreground/50 mb-4" />
                <h3 className="text-lg font-medium">No tasks found</h3>
                <p className="text-muted-foreground mt-2">
                  {selectedJob === 'all' 
                    ? 'Tasks will appear here once created via job setup'
                    : 'No tasks for the selected job'}
                </p>
              </div>
            ) : (
              <div className="space-y-2">
                {tasks.map((task) => (
                  <div
                    key={task.id}
                    className="flex items-center gap-4 p-4 rounded-lg border hover:bg-accent/50 transition-colors"
                    data-testid={`task-row-${task.id}`}
                  >
                    {getStatusIcon(task.status)}
                    
                    <div className="flex-1 min-w-0">
                      <div className="flex items-center gap-2 mb-1">
                        <h3 className="font-medium truncate">{task.task_name}</h3>
                        <Badge variant="outline" className="text-xs">
                          {getJobName(task.job_id)}
                        </Badge>
                      </div>
                      <div className="flex items-center gap-4 text-sm text-muted-foreground">
                        {task.planned_start && (
                          <span className="flex items-center gap-1">
                            <Calendar className="h-3 w-3" />
                            {format(parseISO(task.planned_start), 'MMM d')}
                          </span>
                        )}
                        {task.duration_days && (
                          <span>{task.duration_days} days</span>
                        )}
                        {task.linked_task_codes?.length > 0 && (
                          <span className="flex items-center gap-1">
                            Codes: {task.linked_task_codes.join(', ')}
                          </span>
                        )}
                      </div>
                    </div>

                    <div className="text-right">
                      <Badge variant={getStatusBadgeVariant(task.status)}>
                        {task.status}
                      </Badge>
                      {task.percent_complete > 0 && (
                        <p className="text-sm text-muted-foreground mt-1">
                          {task.percent_complete}% complete
                        </p>
                      )}
                    </div>

                    <Button
                      type="button"
                      variant={task.locked ? "default" : "outline"}
                      size="sm"
                      className="gap-2"
                      onClick={() => toggleLock(task)}
                    >
                      <Lock className="h-4 w-4" />
                      {task.locked ? "Locked" : "Lock"}
                    </Button>

                    {task.quoted_hours && (
                      <div className="text-right hidden md:block">
                        <p className="font-data text-lg font-bold">{task.actual_hours || 0}h</p>
                        <p className="text-xs text-muted-foreground">of {task.quoted_hours}h quoted</p>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}
          </CardContent>
        </Card>
      )}

      {/* Reschedule Confirmation Dialog */}
      <Dialog open={!!rescheduleDialog} onOpenChange={(open) => !open && cancelReschedule()}>
        <DialogContent className="sm:max-w-[500px]">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2">
              <Calendar className="h-5 w-5 text-primary" />
              Confirm Reschedule
            </DialogTitle>
            <DialogDescription>
              Review the schedule change before confirming
            </DialogDescription>
          </DialogHeader>
          
          {rescheduleDialog && (
            <div className="space-y-4 py-4">
              <div className="rounded-lg border p-4 space-y-3">
                <h4 className="font-medium">{rescheduleDialog.task.task_name}</h4>
                
                <div className="grid grid-cols-2 gap-4 text-sm">
                  <div>
                    <p className="text-muted-foreground">Original Dates</p>
                    <p className="font-medium">
                      {rescheduleDialog.originalStart && format(parseISO(rescheduleDialog.originalStart), 'MMM d')}
                      {rescheduleDialog.originalFinish && ` - ${format(parseISO(rescheduleDialog.originalFinish), 'MMM d')}`}
                    </p>
                  </div>
                  <div>
                    <p className="text-muted-foreground">New Dates</p>
                    <p className="font-medium text-primary">
                      {format(parseISO(rescheduleDialog.newDates.planned_start), 'MMM d')}
                      {rescheduleDialog.newDates.planned_finish && ` - ${format(parseISO(rescheduleDialog.newDates.planned_finish), 'MMM d')}`}
                    </p>
                  </div>
                </div>

                <div className="flex items-center gap-2 pt-2">
                  <Badge variant={rescheduleDialog.newDates.daysDelta > 0 ? 'default' : 'secondary'}>
                    {rescheduleDialog.newDates.daysDelta > 0 ? '+' : ''}{rescheduleDialog.newDates.daysDelta} days
                  </Badge>
                  <span className="text-sm text-muted-foreground">
                    {rescheduleDialog.newDates.daysDelta > 0 ? 'Pushed forward' : 'Moved earlier'}
                  </span>
                </div>
              </div>

              {/* Impact Analysis */}
              {impactAnalysis && impactAnalysis.affected_tasks && impactAnalysis.affected_tasks.length > 0 && (
                <div className="rounded-lg border border-amber-200 bg-amber-50 dark:border-amber-800 dark:bg-amber-900/20 p-4">
                  <div className="flex items-start gap-2">
                    <AlertTriangle className="h-5 w-5 text-amber-500 flex-shrink-0 mt-0.5" />
                    <div>
                      <p className="font-medium text-amber-800 dark:text-amber-200">
                        {impactAnalysis.affected_tasks.length} downstream task{impactAnalysis.affected_tasks.length > 1 ? 's' : ''} may be affected
                      </p>
                      <ul className="mt-2 space-y-1">
                        {impactAnalysis.affected_tasks.slice(0, 3).map((affected, idx) => (
                          <li key={idx} className="text-sm text-amber-700 dark:text-amber-300">
                            • {affected.task_name}
                          </li>
                        ))}
                        {impactAnalysis.affected_tasks.length > 3 && (
                          <li className="text-sm text-amber-600">
                            + {impactAnalysis.affected_tasks.length - 3} more
                          </li>
                        )}
                      </ul>
                    </div>
                  </div>
                </div>
              )}
            </div>
          )}

          <DialogFooter>
            <Button type="button" variant="outline" onClick={cancelReschedule}>
              Cancel
            </Button>
            <Button onClick={confirmReschedule} disabled={savingReschedule}>
              {savingReschedule && <Loader2 className="mr-2 h-4 w-4 animate-spin" />}
              Confirm Reschedule
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </div>
  );
}











