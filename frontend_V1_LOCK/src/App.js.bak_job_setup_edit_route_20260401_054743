import DashboardPage from "./pages/DashboardPage.tsx";
import TaskDetailPage from "./pages/TaskDetailPage.tsx";
import JobsPage from "./pages/JobsPage.js";
import JobSetupPage from "./pages/JobSetupPage.js";
import JobDetailPage from "./pages/JobDetailPage.js";
import ResourceAnalysisPage from "./pages/ResourceAnalysisPage.js";
import ReportsPage from "./pages/ReportsPage.js";
import SettingsPage from "./pages/SettingsPage.js";
import TimesheetsPage from "./pages/TimesheetsPage.js";
import LoginPage from "./pages/LoginPage.js";
import GanttPage from "./pages/GanttPage.tsx";
import AppLayout from "./components/AppLayout";

import { AuthProvider } from "./contexts/AuthContext";
import { BrowserRouter, Routes, Route } from "react-router-dom";

export default function App() {
  return (
    <BrowserRouter>
      <AuthProvider>
        <Routes>

          <Route path="/login" element={<LoginPage />} />

          <Route element={<AppLayout />}>

            <Route path="/" element={<JobsPage />} />
            <Route path="/jobs" element={<JobsPage />} />
            <Route path="/jobs/new" element={<JobSetupPage />} />
            <Route path="/jobs/:job_id" element={<JobDetailPage />} />

            <Route path="/jobs/:job_id/dashboard" element={<DashboardPage />} />
            <Route path="/tasks/:task_id" element={<TaskDetailPage />} />

            <Route path="/jobs/:job_id/resources" element={<ResourceAnalysisPage />} />
            <Route path="/jobs/:job_id/gantt" element={<GanttPage />} />

            <Route path="/reports" element={<ReportsPage />} />
            <Route path="/timesheets" element={<TimesheetsPage />} />
            <Route path="/settings" element={<SettingsPage />} />

          </Route>

        </Routes>
      </AuthProvider>
    </BrowserRouter>
  );
}




